<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Template.MobileApp.Controls.CalendarView"
             x:Name="_self">

    <Grid x:Name="RootGrid"
          RowDefinitions="Auto,Auto,Auto,*"
          RowSpacing="0">

        <!-- Header -->
        <ContentView x:Name="HeaderContentHost"
                     Grid.Row="0">
            <Grid x:Name="HeaderGrid"
                  ColumnDefinitions="Auto,*,Auto"
                  Padding="16,12,16,8">
                <Button x:Name="PrevButton"
                        Grid.Column="0"
                        Command="{Binding PrevMonthCommand, Source={x:Reference _self}}"
                        Text="◀"
                        BackgroundColor="Transparent"
                        BorderWidth="0" VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center" Spacing="-2" VerticalOptions="Center">
                    <Label x:Name="YearLabel"
                           HorizontalTextAlignment="Center"
                           Text="" />
                    <Label x:Name="MonthLabel"
                           HorizontalTextAlignment="Center"
                           Text=""
                           FontAttributes="Bold" />
                </VerticalStackLayout>
                <Button x:Name="NextButton"
                        Grid.Column="2"
                        Command="{Binding NextMonthCommand, Source={x:Reference _self}}"
                        Text="▶"
                        BackgroundColor="Transparent"
                        BorderWidth="0" VerticalOptions="Center" />
            </Grid>
        </ContentView>

        <!-- Divider above weekday header -->
        <BoxView Grid.Row="1"
                 HeightRequest="0.5"
                 Color="#E0E0E0" />

        <!-- Day of week header -->
        <Grid x:Name="WeekdayHeaderGrid"
              Grid.Row="2"
              ColumnDefinitions="*,*,*,*,*,*,*"
              Padding="0,6,0,6" />

        <!-- Calendar body -->
        <Grid Grid.Row="3"
              IsClippedToBounds="True">
            <ContentView x:Name="MonthIndicatorHost"
                         InputTransparent="True" />
            <Grid x:Name="WeeksHost"
                  RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
            </Grid>
        </Grid>

    </Grid>

</ContentView>
