<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fonts="clr-namespace:Fonts"
             x:Class="Template.MobileApp.Controls.InfoCard">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Border Padding="0"
                    BackgroundColor="White"
                    Stroke="{StaticResource GrayLighten1}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8">
                <Grid RowDefinitions="Auto,1,Auto">

                    <Grid Grid.Row="0"
                          Padding="12,10"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                        <Label Grid.Column="0"
                               FontFamily="{x:Static fonts:MaterialIcons.FontFamily}"
                               FontSize="24"
                               VerticalOptions="Center"
                               TextColor="{TemplateBinding IconColor}"
                               Text="{TemplateBinding Icon}"
                               IsVisible="{TemplateBinding Icon, Converter={StaticResource NotEmptyConverter}}" />
                        <Label Grid.Column="1"
                               FontSize="20"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{StaticResource BlueGrayDarken2}"
                               Text="{TemplateBinding Title}" />
                    </Grid>

                    <BoxView Grid.Row="1"
                             Color="{StaticResource GrayLighten2}" />

                    <Grid Grid.Row="2"
                          Padding="12,8">
                        <ContentPresenter />
                    </Grid>

                </Grid>
            </Border>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
