<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Navigation.Wizard"
             x:Class="Template.MobileApp.Modules.Navigation.Wizard.WizardInput1View"
             x:DataType="{x:Type module:WizardInput1ViewModel}"
             s:BindingContextResolver.Type="{x:Type module:WizardInput1ViewModel}"
             shell:ShellProperty.Title="Input1"
             shell:ShellProperty.Function1Text="◀️"
             shell:ShellProperty.Function4Text="▶️"
             shell:ShellProperty.Function1Enabled="True"
             shell:ShellProperty.Function4Enabled="{Binding Context.Data1, Converter={StaticResource NotEmptyConverter}}">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="FieldCaptionLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

            <Style x:Key="FieldBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten1}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView BackgroundColor="{StaticResource GrayLighten5}">
        <VerticalStackLayout Padding="12"
                             Spacing="12">

            <controls:StepIndicator Margin="0,8,0,0"
                                    CurrentStep="1"
                                    TotalSteps="3"
                                    behaviors:AnimationOption.EnterAnimation="FadeUp" />

            <controls:InfoCard Title="Step 1 — Data1"
                               Icon="{x:Static fonts:MaterialIcons.Edit}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="80">
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource FieldCaptionLabel}"
                           Text="Data1 (required)" />
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry Placeholder="Data1"
                               Text="{Binding Context.Data1}"
                               behaviors:Focus.FocusedStroke="{StaticResource BlueDefault}"
                               behaviors:Focus.FocusedThickness="2.5" />
                    </Border>
                    <Label Style="{StaticResource FieldCaptionLabel}"
                           Text="Next (▶️) is enabled once this field is filled" />
                </VerticalStackLayout>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
