<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Navigation.Navigate"
             x:Class="Template.MobileApp.Modules.Navigation.Navigate.NavigateCancelView"
             x:DataType="{x:Type module:NavigateCancelViewModel}"
             s:BindingContextResolver.Type="{x:Type module:NavigateCancelViewModel}"
             shell:ShellProperty.Title="Cancel"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <Grid BackgroundColor="{StaticResource GrayLighten5}">

        <Border Margin="16"
                Padding="24"
                VerticalOptions="Center"
                BackgroundColor="White"
                Stroke="{StaticResource GrayLighten1}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                behaviors:AnimationOption.EnterAnimation="FadeUp">
            <VerticalStackLayout Spacing="16">

                <Border Padding="0"
                        WidthRequest="96"
                        HeightRequest="96"
                        HorizontalOptions="Center"
                        BackgroundColor="{StaticResource AmberLighten4}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 48">
                    <Label FontFamily="{x:Static fonts:MaterialIcons.FontFamily}"
                           FontSize="48"
                           TextColor="{StaticResource AmberDarken3}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Text="{x:Static fonts:MaterialIcons.Help}" />
                </Border>

                <Label Style="{StaticResource NameLabel}"
                       HorizontalOptions="Center"
                       Text="Navigation cancel pattern" />

                <BoxView HeightRequest="1"
                         Color="{StaticResource GrayLighten2}" />

                <Label Style="{StaticResource ValueLabel}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Text="A confirm dialog is shown right after navigating here.&#x0a;Yes → return to the menu (cancelled)&#x0a;No → stay on this screen" />

            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentView>
