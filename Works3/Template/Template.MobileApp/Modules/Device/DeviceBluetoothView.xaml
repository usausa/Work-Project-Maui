<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Device"
             x:Class="Template.MobileApp.Modules.Device.DeviceBluetoothView"
             x:DataType="{x:Type module:DeviceBluetoothViewModel}"
             s:BindingContextResolver.Type="{x:Type module:DeviceBluetoothViewModel}"
             shell:ShellProperty.Title="Bluetooth"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootGrid"
                   TargetType="Grid">
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten5}" />
            </Style>

            <Style x:Key="CenterCardBorder"
                   TargetType="Border">
                <Setter Property="Margin" Value="16" />
                <Setter Property="Padding" Value="24" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten1}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16" />
            </Style>

            <Style x:Key="CardStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="16" />
            </Style>

            <Style x:Key="IconCircleBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="0" />
                <Setter Property="WidthRequest" Value="96" />
                <Setter Property="HeightRequest" Value="96" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="BackgroundColor" Value="{StaticResource BlueLighten5}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 48" />
            </Style>

            <Style x:Key="IconCircleLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="{x:Static fonts:MaterialIcons.FontFamily}" />
                <Setter Property="FontSize" Value="48" />
                <Setter Property="TextColor" Value="{StaticResource BlueDefault}" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="CenterTitleLabel"
                   TargetType="Label"
                   BasedOn="{StaticResource NameLabel}">
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="StateChip"
                   TargetType="controls:StatusChip">
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="CenterHintLabel"
                   TargetType="Label"
                   BasedOn="{StaticResource ValueLabel}">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>

            <Style x:Key="PrintButton"
                   TargetType="Button"
                   BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="WidthRequest" Value="200" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>

    <Grid Style="{StaticResource RootGrid}">

        <Border Style="{StaticResource CenterCardBorder}"
                behaviors:AnimationOption.EnterAnimation="FadeUp">
            <VerticalStackLayout Style="{StaticResource CardStack}">

                <Border Style="{StaticResource IconCircleBorder}"
                        behaviors:AnimationOption.Pulse="{Binding IsBusy}">
                    <Label Style="{StaticResource IconCircleLabel}"
                           Text="{x:Static fonts:MaterialIcons.Bluetooth}" />
                </Border>

                <Label Style="{StaticResource CenterTitleLabel}"
                       Text="Bluetooth Serial Print" />

                <controls:StatusChip Style="{StaticResource StateChip}"
                                     Icon="{x:Static fonts:MaterialIcons.Print}"
                                     Text="{Binding State}">
                    <controls:StatusChip.Triggers>
                        <DataTrigger TargetType="controls:StatusChip"
                                     Binding="{Binding State}"
                                     Value="Connecting">
                            <Setter Property="ChipColor" Value="{StaticResource AmberLighten4}" />
                            <Setter Property="IconColor" Value="{StaticResource AmberDarken3}" />
                            <Setter Property="TextColor" Value="{StaticResource AmberDarken3}" />
                        </DataTrigger>
                        <DataTrigger TargetType="controls:StatusChip"
                                     Binding="{Binding State}"
                                     Value="Printing">
                            <Setter Property="ChipColor" Value="{StaticResource BlueLighten4}" />
                            <Setter Property="IconColor" Value="{StaticResource BlueDarken2}" />
                            <Setter Property="TextColor" Value="{StaticResource BlueDarken2}" />
                        </DataTrigger>
                        <DataTrigger TargetType="controls:StatusChip"
                                     Binding="{Binding State}"
                                     Value="Completed">
                            <Setter Property="ChipColor" Value="{StaticResource GreenLighten4}" />
                            <Setter Property="IconColor" Value="{StaticResource GreenDarken2}" />
                            <Setter Property="TextColor" Value="{StaticResource GreenDarken2}" />
                        </DataTrigger>
                        <DataTrigger TargetType="controls:StatusChip"
                                     Binding="{Binding State}"
                                     Value="Failed">
                            <Setter Property="ChipColor" Value="{StaticResource RedLighten4}" />
                            <Setter Property="IconColor" Value="{StaticResource RedDarken2}" />
                            <Setter Property="TextColor" Value="{StaticResource RedDarken2}" />
                        </DataTrigger>
                    </controls:StatusChip.Triggers>
                </controls:StatusChip>

                <Label Style="{StaticResource CenterHintLabel}"
                       Text="{Binding Detail}"
                       behaviors:AnimationOption.FadeInTrigger="{Binding Detail}" />

                <Button Style="{StaticResource PrintButton}"
                        behaviors:ButtonOption.PressEffect="True"
                        Command="{Binding PrintCommand}"
                        Text="Print" />

            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentView>
