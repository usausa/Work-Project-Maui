<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Device"
             x:Class="Template.MobileApp.Modules.Device.DeviceQrDisplayView"
             x:DataType="{x:Type module:DeviceQrDisplayViewModel}"
             s:BindingContextResolver.Type="{x:Type module:DeviceQrDisplayViewModel}"
             shell:ShellProperty.Title="QR Display"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <s:NullToBoolConverter x:Key="EmptyConverter"
                                   HandleEmptyString="True"
                                   NullValue="True"
                                   NonNullValue="False" />

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView BackgroundColor="{StaticResource GrayLighten5}">
        <Grid Padding="16"
              MinimumHeightRequest="560">

            <Border Padding="24"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    Stroke="{StaticResource GrayLighten1}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    behaviors:AnimationOption.EnterAnimation="FadeUp">
                <VerticalStackLayout Spacing="16">

                    <Border Padding="16"
                            HorizontalOptions="Center"
                            BackgroundColor="White"
                            Stroke="{StaticResource GrayLighten2}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                        <Grid WidthRequest="240"
                              HeightRequest="240">
                            <Image Source="{Binding Text, Converter={StaticResource QrImageSourceConverter}}"
                                   IsVisible="{Binding Text, Converter={StaticResource NotEmptyConverter}}" />
                            <VerticalStackLayout VerticalOptions="Center"
                                                 Spacing="8"
                                                 IsVisible="{Binding Text, Converter={StaticResource EmptyConverter}}">
                                <Label FontFamily="{x:Static fonts:MaterialIcons.FontFamily}"
                                       FontSize="48"
                                       TextColor="{StaticResource GrayLighten1}"
                                       HorizontalOptions="Center"
                                       Text="{x:Static fonts:MaterialIcons.Qr_code_2}" />
                                <Label Style="{StaticResource ValueLabel}"
                                       TextColor="{StaticResource GrayLighten1}"
                                       HorizontalOptions="Center"
                                       Text="Enter text to encode" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Label FontFamily="JetBrainsMono"
                           FontSize="14"
                           TextColor="{StaticResource SecondaryTextColor}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="CharacterWrap"
                           Text="{Binding Text}" />

                    <BoxView HeightRequest="1"
                             Color="{StaticResource GrayLighten2}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Style="{StaticResource NameLabel}"
                               Text="Content" />
                        <Border Padding="8,0"
                                BackgroundColor="White"
                                Stroke="{StaticResource GrayLighten1}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Entry Placeholder="Text to encode"
                                   Text="{Binding Text}"
                                   behaviors:Focus.FocusedStroke="{StaticResource BlueDefault}"
                                   behaviors:Focus.FocusedThickness="2.5" />
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

        </Grid>
    </ScrollView>

</ContentView>
