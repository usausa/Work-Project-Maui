<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Device"
             x:Class="Template.MobileApp.Modules.Device.DeviceInfoView"
             x:DataType="{x:Type module:DeviceInfoViewModel}"
             s:BindingContextResolver.Type="{x:Type module:DeviceInfoViewModel}"
             shell:ShellProperty.Title="Info"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="InfoRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnDefinitions" Value="2*,3*" />
                <Setter Property="RowSpacing" Value="8" />
                <Setter Property="Padding" Value="0,4" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView BackgroundColor="{StaticResource GrayLighten5}">
        <VerticalStackLayout Padding="12"
                             Spacing="12">

            <controls:InfoCard Title="Device"
                               Icon="{x:Static fonts:MaterialIcons.Smartphone}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp">
                <Grid Style="{StaticResource InfoRowGrid}"
                      RowDefinitions="Auto,Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Version" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding DeviceVersion}" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Name" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding DeviceName}" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Emulator" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding IsDeviceEmulator}" />
                </Grid>
            </controls:InfoCard>

            <controls:InfoCard Title="Application"
                               Icon="{x:Static fonts:MaterialIcons.Apps}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="100">
                <Grid Style="{StaticResource InfoRowGrid}"
                      RowDefinitions="Auto,Auto,Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Name" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding ApplicationName}" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="PackageName" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding ApplicationPackageName}" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Version" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding ApplicationVersion}" />

                    <Label Grid.Row="3" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Build" />
                    <Label Grid.Row="3" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding ApplicationBuild}" />
                </Grid>
            </controls:InfoCard>

            <controls:InfoCard Title="Display"
                               Icon="{x:Static fonts:MaterialIcons.Aspect_ratio}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="200">
                <Grid Style="{StaticResource InfoRowGrid}"
                      RowDefinitions="Auto,Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Width" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding DisplayWidth, StringFormat='{0:F0} px'}" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Height" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding DisplayHeight, StringFormat='{0:F0} px'}" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Density" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding DisplayDensity, StringFormat='{0:F1}'}" />
                </Grid>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
