<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:markup="clr-namespace:Template.MobileApp.Markup"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Device"
             x:Class="Template.MobileApp.Modules.Device.DeviceMiscView"
             x:DataType="{x:Type module:DeviceMiscViewModel}"
             s:BindingContextResolver.Type="{x:Type module:DeviceMiscViewModel}"
             shell:ShellProperty.Title="Misc"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="ActionButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="ContentLayout" Value="Left,8" />
                <Setter Property="behaviors:ButtonOption.PressEffect" Value="True" />
            </Style>

            <Style x:Key="ActionRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnDefinitions" Value="*,*" />
                <Setter Property="ColumnSpacing" Value="8" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView BackgroundColor="{StaticResource GrayLighten5}">
        <VerticalStackLayout Padding="12"
                             Spacing="12">

            <controls:InfoCard Title="Screen"
                               Icon="{x:Static fonts:MaterialIcons.Smartphone}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp">
                <VerticalStackLayout Spacing="8">
                    <Grid Style="{StaticResource ActionRowGrid}">
                        <Button Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Visibility}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding KeepScreenOnCommand}"
                                Text="Keep on" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Visibility_off}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding KeepScreenOffCommand}"
                                Text="Keep off" />
                    </Grid>
                    <Grid Style="{StaticResource ActionRowGrid}">
                        <Button Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Stay_current_portrait}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding OrientationPortraitCommand}"
                                Text="Portrait" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Stay_current_landscape}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding OrientationLandscapeCommand}"
                                Text="Landscape" />
                    </Grid>
                    <Grid Style="{StaticResource ActionRowGrid}">
                        <Button Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Brightness_low}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding BrightnessCommand}"
                                CommandParameter="{s:Float Value=0.0}"
                                Text="Bright 0" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Brightness_high}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding BrightnessCommand}"
                                CommandParameter="{s:Float Value=1.0}"
                                Text="Bright 1" />
                    </Grid>
                    <Button Style="{StaticResource ActionButton}"
                            ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Screenshot}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                            Command="{Binding ScreenshotCommand}"
                            Text="Screenshot" />
                </VerticalStackLayout>
            </controls:InfoCard>

            <controls:InfoCard Title="Feedback"
                               Icon="{x:Static fonts:MaterialIcons.Vibration}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="80">
                <VerticalStackLayout Spacing="8">
                    <Grid Style="{StaticResource ActionRowGrid}">
                        <Button Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Vibration}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding VibrateCommand}"
                                Text="Vibrate" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Do_not_disturb}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding VibrateCancelCommand}"
                                Text="Cancel" />
                    </Grid>
                    <Grid Style="{StaticResource ActionRowGrid}">
                        <Button Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Touch_app}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding FeedbackClickCommand}"
                                Text="Feed click" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Touch_app}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding FeedbackLongPressCommand}"
                                Text="Feed press" />
                    </Grid>
                </VerticalStackLayout>
            </controls:InfoCard>

            <controls:InfoCard Title="Light"
                               Icon="{x:Static fonts:MaterialIcons.Flashlight_on}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="160">
                <Grid Style="{StaticResource ActionRowGrid}">
                    <Button Grid.Column="0"
                            Style="{StaticResource ActionButton}"
                            ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Flashlight_on}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                            Command="{Binding LightOnCommand}"
                            Text="Light on" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Flashlight_off}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                            Command="{Binding LightOffCommand}"
                            Text="Light off" />
                </Grid>
            </controls:InfoCard>

            <controls:InfoCard Title="Speech"
                               Icon="{x:Static fonts:MaterialIcons.Record_voice_over}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="240">
                <VerticalStackLayout Spacing="8">
                    <Grid Style="{StaticResource ActionRowGrid}">
                        <Button Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Record_voice_over}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding SpeakCommand}"
                                Text="Speak" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Voice_over_off}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding SpeakCancelCommand}"
                                Text="Cancel" />
                    </Grid>
                    <Button Style="{StaticResource ActionButton}"
                            ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Mic}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                            Command="{Binding RecognizeCommand}"
                            Text="Recognize" />

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8"
                          IsVisible="{Binding IsListening}">
                        <Label Grid.Column="0"
                               FontFamily="{x:Static fonts:MaterialIcons.FontFamily}"
                               FontSize="20"
                               TextColor="{StaticResource RedDefault}"
                               VerticalOptions="Center"
                               Text="{x:Static fonts:MaterialIcons.Mic}"
                               behaviors:AnimationOption.Pulse="True" />
                        <Label Grid.Column="1"
                               Style="{StaticResource ValueLabel}"
                               VerticalOptions="Center"
                               Text="Listening..." />
                    </Grid>

                    <Label Style="{StaticResource ValueLabel}"
                           TextColor="{StaticResource PrimaryTextColor}"
                           IsVisible="{Binding RecognizeText, Converter={StaticResource NotEmptyConverter}}"
                           Text="{Binding RecognizeText}"
                           behaviors:AnimationOption.FadeInTrigger="{Binding RecognizeText}" />
                </VerticalStackLayout>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
