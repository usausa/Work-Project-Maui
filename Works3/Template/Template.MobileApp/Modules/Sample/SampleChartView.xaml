<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:graphics="clr-namespace:Template.MobileApp.Graphics"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Sample"
             x:Class="Template.MobileApp.Modules.Sample.SampleChartView"
             x:DataType="{x:Type module:SampleChartViewModel}"
             s:BindingContextResolver.Type="{x:Type module:SampleChartViewModel}"
             shell:ShellProperty.Title="Chart"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="SegmentButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="0" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="{StaticResource BlueDefault}" />
                <Setter Property="BorderColor" Value="{StaticResource BlueLighten3}" />
                <Setter Property="BorderWidth" Value="1" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="Auto,*"
          BackgroundColor="White">

        <!-- 切替セグメント -->
        <Grid Grid.Row="0"
              Margin="16,12"
              ColumnDefinitions="*,*,*,*"
              ColumnSpacing="8">
            <Button Grid.Column="0"
                    Style="{StaticResource SegmentButton}"
                    Command="{Binding SelectCommand}"
                    CommandParameter="{x:Static graphics:ChartKind.Line}"
                    Text="Line">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding Kind}"
                                 Value="{x:Static graphics:ChartKind.Line}">
                        <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Grid.Column="1"
                    Style="{StaticResource SegmentButton}"
                    Command="{Binding SelectCommand}"
                    CommandParameter="{x:Static graphics:ChartKind.Bar}"
                    Text="Bar">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding Kind}"
                                 Value="{x:Static graphics:ChartKind.Bar}">
                        <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Grid.Column="2"
                    Style="{StaticResource SegmentButton}"
                    Command="{Binding SelectCommand}"
                    CommandParameter="{x:Static graphics:ChartKind.Donut}"
                    Text="Donut">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding Kind}"
                                 Value="{x:Static graphics:ChartKind.Donut}">
                        <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Grid.Column="3"
                    Style="{StaticResource SegmentButton}"
                    Command="{Binding SelectCommand}"
                    CommandParameter="{x:Static graphics:ChartKind.Candle}"
                    Text="Candle">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding Kind}"
                                 Value="{x:Static graphics:ChartKind.Candle}">
                        <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <!-- チャート -->
        <graphics:GraphicsControl Grid.Row="1"
                                  Margin="8,0,8,16"
                                  Graphics="{Binding Graphics}" />

    </Grid>

</ContentView>
