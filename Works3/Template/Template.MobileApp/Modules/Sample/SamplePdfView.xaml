<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Sample"
             xmlns:pdf="clr-namespace:Maui.PDFView;assembly=Maui.PDFView"
             x:Class="Template.MobileApp.Modules.Sample.SamplePdfView"
             x:DataType="{x:Type module:SamplePdfViewModel}"
             s:BindingContextResolver.Type="{x:Type module:SamplePdfViewModel}"
             shell:ShellProperty.Title="Pdf"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function3Text="◀️"
             shell:ShellProperty.Function4Text="▶️"
             shell:ShellProperty.Function1Enabled="True"
             shell:ShellProperty.Function3Enabled="{Binding CanMovePrev}"
             shell:ShellProperty.Function4Enabled="{Binding CanMoveNext}">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="PageEdgeButton"
                   TargetType="Button">
                <Setter Property="WidthRequest" Value="56" />
                <Setter Property="VerticalOptions" Value="Fill" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

            <Style x:Key="PageSlider"
                   TargetType="Slider">
                <Setter Property="Margin" Value="16,0" />
                <Setter Property="ThumbColor" Value="{StaticResource BlueDarken2}" />
                <Setter Property="MinimumTrackColor" Value="{StaticResource BlueDarken2}" />
                <Setter Property="MaximumTrackColor" Value="{StaticResource GrayLighten2}" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="*,Auto,Auto">

        <pdf:PdfView Grid.Row="0"
                     PageIndex="{Binding PageIndex, Mode=TwoWay}"
                     MaxZoom="4"
                     PageChangedCommand="{Binding PageChangedCommand}"
                     Uri="{Binding PdfSource}" />

        <!-- 画面端タップで前後ページ -->
        <Button Grid.Row="0"
                Style="{StaticResource PageEdgeButton}"
                HorizontalOptions="Start"
                Command="{Binding PrevPageCommand}"
                IsEnabled="{Binding CanMovePrev}" />
        <Button Grid.Row="0"
                Style="{StaticResource PageEdgeButton}"
                HorizontalOptions="End"
                Command="{Binding NextPageCommand}"
                IsEnabled="{Binding CanMoveNext}" />

        <Slider Grid.Row="1"
                Style="{StaticResource PageSlider}"
                Minimum="0"
                Maximum="{Binding MaxPageIndex}"
                Value="{Binding PageIndex, Mode=TwoWay}" />

        <Label Grid.Row="2"
               Style="{StaticResource ValueLabel}"
               StyleClass="LabelCenter"
               Text="{Binding PageInformation}" />

    </Grid>

</ContentView>
