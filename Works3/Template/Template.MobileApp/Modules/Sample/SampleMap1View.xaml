<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:models="clr-namespace:Template.MobileApp.Models.Sample"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Sample"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="Template.MobileApp.Modules.Sample.SampleMap1View"
             x:DataType="{x:Type module:SampleMap1ViewModel}"
             s:BindingContextResolver.Type="{x:Type module:SampleMap1ViewModel}"
             shell:ShellProperty.Title="Map"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="MapFabButton"
                   TargetType="ImageButton">
                <Setter Property="WidthRequest" Value="48" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="CornerRadius" Value="24" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="BackgroundColor" Value="#E6FFFFFF" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="Black"
                                Opacity="0.3"
                                Radius="6"
                                Offset="0,2" />
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}">

        <maps:Map behaviors:MapBind.Controller="{Binding Controller}"
                  MapType="{Binding CurrentMapType}"
                  ItemsSource="{Binding Spots}">
            <maps:Map.ItemTemplate>
                <DataTemplate x:DataType="{x:Type models:MapSpot}">
                    <maps:Pin Location="{Binding Location}"
                              Label="{Binding Name}"
                              Address="{Binding Description}" />
                </DataTemplate>
            </maps:Map.ItemTemplate>
        </maps:Map>

        <VerticalStackLayout Margin="0,0,16,16"
                             HorizontalOptions="End"
                             VerticalOptions="End"
                             Spacing="12">
            <ImageButton Style="{StaticResource MapFabButton}"
                         Command="{Binding ToggleMapTypeCommand}">
                <ImageButton.Source>
                    <FontImageSource Glyph="{x:Static fonts:MaterialIcons.Layers}"
                                     FontFamily="MaterialIcons"
                                     Color="{StaticResource GrayDarken3}"
                                     Size="24" />
                </ImageButton.Source>
            </ImageButton>
            <ImageButton Style="{StaticResource MapFabButton}"
                         Command="{Binding HomeCommand}">
                <ImageButton.Source>
                    <FontImageSource Glyph="{x:Static fonts:MaterialIcons.Home}"
                                     FontFamily="MaterialIcons"
                                     Color="{StaticResource GrayDarken3}"
                                     Size="24" />
                </ImageButton.Source>
            </ImageButton>
        </VerticalStackLayout>

    </Grid>

</ContentView>
