<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:markup="clr-namespace:Template.MobileApp.Markup"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Sample"
             x:Class="Template.MobileApp.Modules.Sample.SampleCvNetMenuView"
             x:DataType="{x:Type module:SampleCvNetMenuViewModel}"
             s:BindingContextResolver.Type="{x:Type module:SampleCvNetMenuViewModel}"
             shell:ShellProperty.Title="CV Net"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <Grid Style="{StaticResource MenuGrid}"
          RowDefinitions="*,*,*,*,*,*,*,*,*">
        <Button Grid.Row="0"
                Style="{StaticResource MenuIconButton}"
                Command="{Binding ForwardCommand}"
                CommandParameter="{markup:ViewId SampleCvNetObject}"
                Text="Object"
                ImageSource="{markup:MenuIcon {x:Static fonts:MaterialIcons.Category}}" />
        <Button Grid.Row="1"
                Style="{StaticResource MenuIconButton}"
                Command="{Binding ForwardCommand}"
                CommandParameter="{markup:ViewId SampleCvNetTag}"
                Text="Tag"
                ImageSource="{markup:MenuIcon {x:Static fonts:MaterialIcons.Sell}}" />
        <Button Grid.Row="2"
                Style="{StaticResource MenuIconButton}"
                Command="{Binding ForwardCommand}"
                CommandParameter="{markup:ViewId SampleCvNetPeople}"
                Text="People"
                ImageSource="{markup:MenuIcon {x:Static fonts:MaterialIcons.People}}" />
        <Button Grid.Row="3"
                Style="{StaticResource MenuIconButton}"
                Command="{Binding ForwardCommand}"
                CommandParameter="{markup:ViewId SampleCvNetOcr}"
                Text="Ocr"
                ImageSource="{markup:MenuIcon {x:Static fonts:MaterialIcons.Document_scanner}}" />
        <Button Grid.Row="4"
                Style="{StaticResource MenuIconButton}"
                Command="{Binding ForwardCommand}"
                CommandParameter="{markup:ViewId SampleCvNetFace}"
                Text="Face"
                ImageSource="{markup:MenuIcon {x:Static fonts:MaterialIcons.Face}}" />
        <Button Grid.Row="5"
                Style="{StaticResource MenuButton}"
                IsEnabled="False"
                IsVisible="False"
                Text="" />
        <Button Grid.Row="6"
                Style="{StaticResource MenuButton}"
                IsEnabled="False"
                IsVisible="False"
                Text="" />
        <Button Grid.Row="7"
                Style="{StaticResource MenuButton}"
                IsEnabled="False"
                IsVisible="False"
                Text="" />
        <Button Grid.Row="8"
                Style="{StaticResource MenuButton}"
                IsEnabled="False"
                IsVisible="False"
                Text="" />
    </Grid>

</ContentView>
