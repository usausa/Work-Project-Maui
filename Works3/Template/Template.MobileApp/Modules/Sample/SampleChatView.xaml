<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Sample"
             x:Class="Template.MobileApp.Modules.Sample.SampleChatView"
             x:DataType="{x:Type module:SampleChatViewModel}"
             s:BindingContextResolver.Type="{x:Type module:SampleChatViewModel}"
             shell:ShellProperty.Title="Chat"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <controls:ChatView Messages="{Binding Messages}"
                       InputText="{Binding InputText, Mode=TwoWay}"
                       SendCommand="{Binding SendCommand}" />

</ContentView>
