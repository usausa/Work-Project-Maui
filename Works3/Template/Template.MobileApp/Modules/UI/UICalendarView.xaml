<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UICalendarView"
             x:DataType="{x:Type module:UICalendarViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UICalendarViewModel}"
             shell:ShellProperty.Title="Calendar"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>
            <Style x:Key="CalendarDivider"
                   TargetType="BoxView">
                <Setter Property="HeightRequest" Value="0.5" />
                <Setter Property="Color" Value="#E0E0E0" />
            </Style>
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="*,Auto,Auto"
          BackgroundColor="White"
          RowSpacing="0">

        <controls:CalendarView Grid.Row="0"
                               Culture="{Binding Culture}"
                               DayTappedCommand="{Binding DayTappedCommand}"
                               EventTappedCommand="{Binding EventTappedCommand}"
                               FirstDayOfWeek="{Binding FirstDayOfWeek}"
                               GoToTodayCommand="{Binding GoToTodayCommand}"
                               MaxDate="{Binding MaxDate}"
                               MinDate="{Binding MinDate}"
                               NextMonthCommand="{Binding NextMonthCommand}"
                               PrevMonthCommand="{Binding PrevMonthCommand}"
                               SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                               SelectedDates="{Binding SelectedDates}"
                               SelectedEndDate="{Binding SelectedEndDate, Mode=TwoWay}"
                               SelectedStartDate="{Binding SelectedStartDate, Mode=TwoWay}"
                               SelectionMode="{Binding SelectionMode}"
                               View="{Binding MonthView}" />

        <BoxView Grid.Row="1"
                 Style="{StaticResource CalendarDivider}" />

    </Grid>

</ContentView>
