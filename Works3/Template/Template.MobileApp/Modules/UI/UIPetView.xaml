<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UIPetView"
             x:DataType="{x:Type module:UIPetViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UIPetViewModel}"
             shell:ShellProperty.Title="Pet"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <ContentView.Resources>
        <ResourceDictionary>

            <!-- Hero -->
            <Style x:Key="HeroImage"
                   TargetType="Image">
                <Setter Property="Aspect" Value="AspectFill" />
            </Style>

            <Style x:Key="DetailCardBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="20,16,20,8" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 40,40,0,0" />
            </Style>

            <!-- Name + level -->
            <Style x:Key="NameRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="12" />
            </Style>

            <Style x:Key="PetNameLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken4}" />
            </Style>

            <Style x:Key="BreedLabel"
                   TargetType="Label">
                <Setter Property="Margin" Value="8,0,0,5" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken1}" />
                <Setter Property="HorizontalOptions" Value="Start" />
                <Setter Property="VerticalOptions" Value="End" />
            </Style>

            <Style x:Key="LevelBadgeBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="12,5" />
                <Setter Property="VerticalOptions" Value="Start" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="BackgroundColor" Value="{StaticResource AmberDefault}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14" />
            </Style>

            <Style x:Key="LevelBadgeLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <!-- Type tags -->
            <Style x:Key="TagRow"
                   TargetType="HorizontalStackLayout">
                <Setter Property="Spacing" Value="6" />
                <Setter Property="Margin" Value="0,10,0,0" />
            </Style>

            <Style x:Key="TagBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="12,5" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 13" />
            </Style>

            <Style x:Key="TagLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <!-- Base stats: fill ratio is expressed by star-sized columns (e.g. 80*/20*) -->
            <Style x:Key="StatStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="8" />
                <Setter Property="Margin" Value="0,14,0,0" />
            </Style>

            <Style x:Key="StatRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="8" />
            </Style>

            <Style x:Key="StatNameLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken1}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="StatBarGrid"
                   TargetType="Grid">
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="StatTrack"
                   TargetType="Border">
                <Setter Property="HeightRequest" Value="6" />
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten3}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 3" />
            </Style>

            <Style x:Key="StatFillHp"
                   TargetType="Border"
                   BasedOn="{StaticResource StatTrack}">
                <Setter Property="BackgroundColor" Value="{StaticResource GreenDefault}" />
            </Style>

            <Style x:Key="StatFillAttack"
                   TargetType="Border"
                   BasedOn="{StaticResource StatTrack}">
                <Setter Property="BackgroundColor" Value="{StaticResource OrangeDefault}" />
            </Style>

            <Style x:Key="StatFillDefense"
                   TargetType="Border"
                   BasedOn="{StaticResource StatTrack}">
                <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
            </Style>

            <Style x:Key="StatFillSpeed"
                   TargetType="Border"
                   BasedOn="{StaticResource StatTrack}">
                <Setter Property="BackgroundColor" Value="{StaticResource AmberDefault}" />
            </Style>

            <Style x:Key="StatValueLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken3}" />
                <Setter Property="HorizontalTextAlignment" Value="End" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <!-- Flavor text -->
            <Style x:Key="FlavorBorder"
                   TargetType="Border">
                <Setter Property="Margin" Value="0,12,0,0" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="BackgroundColor" Value="{StaticResource AmberLighten5}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            </Style>

            <Style x:Key="FlavorGrid"
                   TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="8" />
            </Style>

            <Style x:Key="FlavorQuoteIcon"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="MaterialIcons" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="TextColor" Value="{StaticResource AmberDarken2}" />
                <Setter Property="VerticalOptions" Value="Start" />
            </Style>

            <Style x:Key="FlavorLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Italic" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken2}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>

            <!-- Actions -->
            <Style x:Key="ButtonRow"
                   TargetType="Grid">
                <Setter Property="Margin" Value="0,12,0,8" />
                <Setter Property="ColumnSpacing" Value="12" />
            </Style>

            <Style x:Key="HeartButton"
                   TargetType="Button">
                <Setter Property="WidthRequest" Value="56" />
                <Setter Property="HeightRequest" Value="56" />
                <Setter Property="CornerRadius" Value="28" />
                <Setter Property="BackgroundColor" Value="{StaticResource RedLighten4}" />
                <Setter Property="TextColor" Value="{StaticResource RedDefault}" />
                <Setter Property="FontFamily" Value="MaterialIcons" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="Shadow">
                    <Shadow Offset="0,3"
                            Brush="Black" Opacity="0.2" Radius="6" />
                </Setter>
            </Style>

            <Style x:Key="PartyButton"
                   TargetType="Button">
                <Setter Property="HeightRequest" Value="56" />
                <Setter Property="CornerRadius" Value="28" />
                <Setter Property="BackgroundColor" Value="{StaticResource AmberDefault}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Shadow">
                    <Shadow Offset="0,3"
                            Brush="Black" Opacity="0.2" Radius="6" />
                </Setter>
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>

    <!-- Rows 0-1: hero image / rows 1-2: sheet card. The shared 40px row makes the card overlap the image without negative margins -->
    <Grid RowDefinitions="*,40,Auto">
        <Image Grid.Row="0" Grid.RowSpan="2"
               Style="{StaticResource HeroImage}"
               Source="usa1_full.jpg" />

        <Border Grid.Row="1" Grid.RowSpan="2"
                Style="{StaticResource DetailCardBorder}">
            <VerticalStackLayout>

                <Grid Style="{StaticResource NameRowGrid}"
                      ColumnDefinitions="Auto,*,Auto">
                    <Label Grid.Column="0"
                           Style="{StaticResource PetNameLabel}"
                           Text="{Binding PetName}" />
                    <Label Grid.Column="1"
                           Style="{StaticResource BreedLabel}"
                           Text="{Binding Breed}" />
                    <Border Grid.Column="2"
                            Style="{StaticResource LevelBadgeBorder}">
                        <Label Style="{StaticResource LevelBadgeLabel}"
                               Text="{Binding Level}" />
                    </Border>
                </Grid>

                <!-- Type tags -->
                <HorizontalStackLayout Style="{StaticResource TagRow}"
                                       BindableLayout.ItemsSource="{Binding Tags}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="module:UIPetTag">
                            <Border Style="{StaticResource TagBorder}"
                                    BackgroundColor="{Binding BackgroundColor}">
                                <Label Style="{StaticResource TagLabel}"
                                       Text="{Binding Label}"
                                       TextColor="{Binding TextColor}" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>

                <!-- Base stats -->
                <VerticalStackLayout Style="{StaticResource StatStack}">
                    <Grid Style="{StaticResource StatRowGrid}"
                          ColumnDefinitions="56,*,34">
                        <Label Grid.Column="0"
                               Style="{StaticResource StatNameLabel}"
                               Text="HP" />
                        <Grid Grid.Column="1"
                              Style="{StaticResource StatBarGrid}"
                              ColumnDefinitions="80*,20*">
                            <Border Grid.ColumnSpan="2"
                                    Style="{StaticResource StatTrack}" />
                            <Border Grid.Column="0"
                                    Style="{StaticResource StatFillHp}" />
                        </Grid>
                        <Label Grid.Column="2"
                               Style="{StaticResource StatValueLabel}"
                               Text="320" />
                    </Grid>
                    <Grid Style="{StaticResource StatRowGrid}"
                          ColumnDefinitions="56,*,34">
                        <Label Grid.Column="0"
                               Style="{StaticResource StatNameLabel}"
                               Text="Attack" />
                        <Grid Grid.Column="1"
                              Style="{StaticResource StatBarGrid}"
                              ColumnDefinitions="78*,22*">
                            <Border Grid.ColumnSpan="2"
                                    Style="{StaticResource StatTrack}" />
                            <Border Grid.Column="0"
                                    Style="{StaticResource StatFillAttack}" />
                        </Grid>
                        <Label Grid.Column="2"
                               Style="{StaticResource StatValueLabel}"
                               Text="78" />
                    </Grid>
                    <Grid Style="{StaticResource StatRowGrid}"
                          ColumnDefinitions="56,*,34">
                        <Label Grid.Column="0"
                               Style="{StaticResource StatNameLabel}"
                               Text="Defense" />
                        <Grid Grid.Column="1"
                              Style="{StaticResource StatBarGrid}"
                              ColumnDefinitions="64*,36*">
                            <Border Grid.ColumnSpan="2"
                                    Style="{StaticResource StatTrack}" />
                            <Border Grid.Column="0"
                                    Style="{StaticResource StatFillDefense}" />
                        </Grid>
                        <Label Grid.Column="2"
                               Style="{StaticResource StatValueLabel}"
                               Text="64" />
                    </Grid>
                    <Grid Style="{StaticResource StatRowGrid}"
                          ColumnDefinitions="56,*,34">
                        <Label Grid.Column="0"
                               Style="{StaticResource StatNameLabel}"
                               Text="Speed" />
                        <Grid Grid.Column="1"
                              Style="{StaticResource StatBarGrid}"
                              ColumnDefinitions="92*,8*">
                            <Border Grid.ColumnSpan="2"
                                    Style="{StaticResource StatTrack}" />
                            <Border Grid.Column="0"
                                    Style="{StaticResource StatFillSpeed}" />
                        </Grid>
                        <Label Grid.Column="2"
                               Style="{StaticResource StatValueLabel}"
                               Text="92" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Flavor text -->
                <Border Style="{StaticResource FlavorBorder}">
                    <Grid Style="{StaticResource FlavorGrid}"
                          ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0"
                               Style="{StaticResource FlavorQuoteIcon}"
                               Text="{x:Static fonts:MaterialIcons.Format_quote}" />
                        <Label Grid.Column="1"
                               Style="{StaticResource FlavorLabel}"
                               Text="{Binding FlavorText}" />
                    </Grid>
                </Border>

                <!-- Actions -->
                <Grid Style="{StaticResource ButtonRow}"
                      ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Style="{StaticResource HeartButton}"
                            Text="{x:Static fonts:MaterialIcons.Favorite}" />
                    <Button Grid.Column="1"
                            Style="{StaticResource PartyButton}"
                            Text="Add to Party" />
                </Grid>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentView>
