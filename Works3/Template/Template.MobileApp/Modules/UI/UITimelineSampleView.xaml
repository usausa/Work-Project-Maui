<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UITimelineSampleView"
             x:DataType="{x:Type module:UITimelineSampleViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UITimelineSampleViewModel}"
             shell:ShellProperty.Title="Timeline Sample"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootGrid" TargetType="Grid">
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten4}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="RowSpacing" Value="12" />
            </Style>

            <!-- Header -->
            <Style x:Key="HeaderGrid" TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="12" />
            </Style>

            <Style x:Key="CalendarIconBorder" TargetType="Border">
                <Setter Property="WidthRequest" Value="44" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Shadow">
                    <Shadow Offset="0,2"
                            Brush="Black" Opacity="0.15" Radius="6" />
                </Setter>
            </Style>

            <Style x:Key="CalendarIconLabel" TargetType="Label">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="FontFamily" Value="MaterialIcons" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style x:Key="DateCaptionLabel" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken1}" />
            </Style>

            <Style x:Key="DateLabel" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken4}" />
            </Style>

            <!-- Timeline items -->
            <Style x:Key="TimelineCollection" TargetType="CollectionView">
                <Setter Property="VerticalScrollBarVisibility" Value="Never" />
            </Style>

            <Style x:Key="EventRowGrid" TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="10" />
            </Style>

            <Style x:Key="TimeLabel" TargetType="Label">
                <Setter Property="WidthRequest" Value="50" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="End" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueDefault}" />
            </Style>

            <Style x:Key="TimelineLine" TargetType="BoxView">
                <Setter Property="WidthRequest" Value="2" />
                <Setter Property="Color" Value="{StaticResource GrayLighten1}" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <!-- Dot fill/stroke are set per-item via bindings (status-driven) -->
            <Style x:Key="TimelineDot" TargetType="Ellipse">
                <Setter Property="WidthRequest" Value="16" />
                <Setter Property="HeightRequest" Value="16" />
                <Setter Property="StrokeThickness" Value="2" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="TimelineDotHalo" TargetType="Ellipse">
                <Setter Property="WidthRequest" Value="22" />
                <Setter Property="HeightRequest" Value="22" />
                <Setter Property="Opacity" Value="0.25" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="DotCheckLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="MaterialIcons" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="EventCardBorder" TargetType="Border">
                <Setter Property="Padding" Value="14" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16" />
                <Setter Property="Margin" Value="0,4,0,8" />
                <Setter Property="Shadow">
                    <Shadow Offset="0,2"
                            Brush="Black" Opacity="0.1" Radius="10" />
                </Setter>
            </Style>

            <Style x:Key="EventTitleRow" TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="8" />
            </Style>

            <Style x:Key="EventTitleLabel" TargetType="Label">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken4}" />
            </Style>

            <!-- Badge background is set per-item via DotColor binding -->
            <Style x:Key="NowBadgeBorder" TargetType="Border">
                <Setter Property="Padding" Value="7,2" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 9" />
                <Setter Property="VerticalOptions" Value="Start" />
            </Style>

            <Style x:Key="NowBadgeLabel" TargetType="Label">
                <Setter Property="FontSize" Value="9" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style x:Key="EventDescLabel" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken2}" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <Style x:Key="TagRow" TargetType="HorizontalStackLayout">
                <Setter Property="Spacing" Value="6" />
                <Setter Property="Margin" Value="0,8,0,0" />
            </Style>

            <Style x:Key="TagBorder" TargetType="Border">
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="BackgroundColor" Value="{StaticResource BlueLighten5}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
            </Style>

            <Style x:Key="TagContentRow" TargetType="HorizontalStackLayout">
                <Setter Property="Spacing" Value="3" />
            </Style>

            <Style x:Key="TagIcon" TargetType="Label">
                <Setter Property="FontFamily" Value="MaterialIcons" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="TextColor" Value="{StaticResource BlueDarken2}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="TagLabel" TargetType="Label">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="TextColor" Value="{StaticResource BlueDarken2}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>

    <Grid Style="{StaticResource RootGrid}"
          RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              Style="{StaticResource HeaderGrid}"
              ColumnDefinitions="Auto,*">
            <Border Grid.Column="0" Style="{StaticResource CalendarIconBorder}">
                <Label Style="{StaticResource CalendarIconLabel}"
                       Text="{x:Static fonts:MaterialIcons.Calendar_today}" />
            </Border>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                <Label Style="{StaticResource DateCaptionLabel}" Text="本日のスケジュール" />
                <Label Style="{StaticResource DateLabel}" Text="{Binding DateLabel}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Timeline list -->
        <CollectionView Grid.Row="1"
                        Style="{StaticResource TimelineCollection}"
                        behaviors:Scroll.DisableOverScroll="True"
                        ItemsSource="{Binding Events}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="module:UITimelineSampleEvent">
                    <Grid Style="{StaticResource EventRowGrid}"
                          Opacity="{Binding RowOpacity}"
                          ColumnDefinitions="Auto,Auto,*">

                        <!-- Time -->
                        <Label Grid.Column="0"
                               Style="{StaticResource TimeLabel}"
                               Text="{Binding Time}" />

                        <!-- Dot + line (done: check / current: halo / upcoming: hollow) -->
                        <Grid Grid.Column="1"
                              WidthRequest="22"
                              RowDefinitions="*">
                            <BoxView Style="{StaticResource TimelineLine}" />
                            <Ellipse Style="{StaticResource TimelineDotHalo}"
                                     IsVisible="{Binding Current}"
                                     Fill="{Binding DotColor}" />
                            <Ellipse Style="{StaticResource TimelineDot}"
                                     Fill="{Binding DotFill}"
                                     Stroke="{Binding DotStroke}" />
                            <Label Style="{StaticResource DotCheckLabel}"
                                   IsVisible="{Binding Done}"
                                   Text="{x:Static fonts:MaterialIcons.Check}" />
                        </Grid>

                        <!-- Card with title, status badge, description, tags -->
                        <Border Grid.Column="2" Style="{StaticResource EventCardBorder}">
                            <VerticalStackLayout>
                                <Grid Style="{StaticResource EventTitleRow}"
                                      ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Style="{StaticResource EventTitleLabel}"
                                           Text="{Binding Title}" />
                                    <Border Grid.Column="1"
                                            Style="{StaticResource NowBadgeBorder}"
                                            IsVisible="{Binding Current}"
                                            BackgroundColor="{Binding DotColor}">
                                        <Label Style="{StaticResource NowBadgeLabel}"
                                               Text="進行中" />
                                    </Border>
                                </Grid>
                                <Label Style="{StaticResource EventDescLabel}" Text="{Binding Description}" />
                                <HorizontalStackLayout Style="{StaticResource TagRow}">
                                    <Border Style="{StaticResource TagBorder}">
                                        <HorizontalStackLayout Style="{StaticResource TagContentRow}">
                                            <Label Style="{StaticResource TagIcon}"
                                                   Text="{x:Static fonts:MaterialIcons.Tag}" />
                                            <Label Style="{StaticResource TagLabel}" Text="{Binding Tag1}" />
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border Style="{StaticResource TagBorder}">
                                        <HorizontalStackLayout Style="{StaticResource TagContentRow}">
                                            <Label Style="{StaticResource TagIcon}"
                                                   Text="{x:Static fonts:MaterialIcons.Tag}" />
                                            <Label Style="{StaticResource TagLabel}" Text="{Binding Tag2}" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentView>
