<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UIKitTrackingView"
             x:DataType="{x:Type module:UIKitTrackingViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UIKitTrackingViewModel}"
             shell:ShellProperty.Title="Kit Tracking"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootScroll" TargetType="ScrollView">
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

            <Style x:Key="HeaderBorder" TargetType="Border">
                <Setter Property="Margin" Value="16" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="BackgroundColor" Value="{StaticResource BlueLighten4}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14" />
            </Style>

            <Style x:Key="OrderCaption" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken1}" />
            </Style>

            <Style x:Key="OrderValue" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueDarken1}" />
            </Style>

            <Style x:Key="EtaLabel" TargetType="Label">
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken3}" />
            </Style>

            <Style x:Key="StepRow" TargetType="Grid">
                <Setter Property="Margin" Value="24,0" />
                <Setter Property="HeightRequest" Value="80" />
            </Style>

            <Style x:Key="DotComplete" TargetType="Ellipse">
                <Setter Property="WidthRequest" Value="18" />
                <Setter Property="HeightRequest" Value="18" />
                <Setter Property="Fill" Value="{StaticResource GreenDefault}" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Start" />
            </Style>

            <Style x:Key="DotPending" TargetType="Ellipse">
                <Setter Property="WidthRequest" Value="18" />
                <Setter Property="HeightRequest" Value="18" />
                <Setter Property="Fill" Value="{StaticResource GrayLighten2}" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Start" />
            </Style>

            <Style x:Key="TimelineLine" TargetType="BoxView">
                <Setter Property="WidthRequest" Value="2" />
                <Setter Property="Color" Value="{StaticResource GrayLighten2}" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="Margin" Value="0,18,0,0" />
            </Style>

            <Style x:Key="StepTitle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken4}" />
            </Style>

            <Style x:Key="StepTime" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken1}" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>

    <ScrollView Style="{StaticResource RootScroll}">
        <VerticalStackLayout>
            <Border Style="{StaticResource HeaderBorder}">
                <VerticalStackLayout>
                    <Label Style="{StaticResource OrderCaption}" Text="Order Number" />
                    <Label Style="{StaticResource OrderValue}" Text="{Binding OrderNumber}" />
                    <Label Style="{StaticResource EtaLabel}" Text="{Binding Eta}" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Steps}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="module:UIKitTrackingStep">
                        <Grid Style="{StaticResource StepRow}"
                              ColumnDefinitions="40,*">
                            <Grid Grid.Column="0">
                                <BoxView Style="{StaticResource TimelineLine}" />
                                <Ellipse Style="{StaticResource DotComplete}"
                                         IsVisible="{Binding IsComplete}" />
                                <Ellipse Style="{StaticResource DotPending}"
                                         IsVisible="{Binding IsPending}" />
                            </Grid>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Style="{StaticResource StepTitle}" Text="{Binding Title}" />
                                <Label Style="{StaticResource StepTime}" Text="{Binding Time}" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentView>
