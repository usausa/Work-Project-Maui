<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:calendar="clr-namespace:Template.MobileApp.Models.Sample.Calendar"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UIScheduleView"
             x:DataType="{x:Type module:UIScheduleViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UIScheduleViewModel}"
             shell:ShellProperty.Title="Schedule"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="DayChipGrid"
                   TargetType="Grid">
                <Setter Property="WidthRequest" Value="56" />
                <Setter Property="Padding" Value="0,8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

            <Style x:Key="DayChipBorder"
                   TargetType="Border">
                <Setter Property="WidthRequest" Value="44" />
                <Setter Property="HeightRequest" Value="60" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 22" />
            </Style>

            <Style x:Key="DayChipDowLabel"
                   TargetType="Label">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource GrayDefault}" />
            </Style>

            <Style x:Key="DayChipDayLabel"
                   TargetType="Label">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken3}" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="Auto,*"
          BackgroundColor="White">

        <!-- 7 日チップ -->
        <CollectionView Grid.Row="0"
                        HeightRequest="84"
                        ItemsSource="{Binding Days}"
                        SelectedItem="{Binding SelectedDay, Mode=TwoWay}"
                        SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="0" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="{x:Type calendar:TimetableDay}">
                    <Grid Style="{StaticResource DayChipGrid}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                            <Setter TargetName="ChipBorder" Property="Border.BackgroundColor" Value="{StaticResource BlueDefault}" />
                                            <Setter TargetName="ChipDow" Property="Label.TextColor" Value="White" />
                                            <Setter TargetName="ChipDay" Property="Label.TextColor" Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                        <Border x:Name="ChipBorder"
                                Style="{StaticResource DayChipBorder}">
                            <VerticalStackLayout VerticalOptions="Center"
                                                 Spacing="2">
                                <Label x:Name="ChipDow"
                                       Style="{StaticResource DayChipDowLabel}"
                                       Text="{Binding DowText}" />
                                <Label x:Name="ChipDay"
                                       Style="{StaticResource DayChipDayLabel}"
                                       Text="{Binding Day}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- タイムテーブル -->
        <ScrollView Grid.Row="1">
            <controls:DayTimetableView Events="{Binding Events}"
                                       CurrentTime="{Binding CurrentTime}"
                                       ShowCurrentTime="{Binding ShowCurrentTime}" />
        </ScrollView>

    </Grid>

</ContentView>
