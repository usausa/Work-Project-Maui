<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UICockpitView"
             x:DataType="{x:Type module:UICockpitViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UICockpitViewModel}"
             shell:ShellProperty.Title="Cockpit"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <!-- 黒背景+アンバー/グリーン照明のコックピット計器 -->
            <Style x:Key="CockpitGauge"
                   TargetType="controls:Gauge">
                <Setter Property="GaugeBackgroundColor" Value="#141A20" />
                <Setter Property="GaugeBackgroundColor2" Value="#0C1014" />
                <Setter Property="BezelOuterStartColor" Value="#3A424A" />
                <Setter Property="BezelOuterEndColor" Value="#14181C" />
                <Setter Property="BezelInnerStartColor" Value="#22282E" />
                <Setter Property="BezelInnerEndColor" Value="#3A424A" />
                <Setter Property="ArcTrackColor" Value="#2A3238" />
                <Setter Property="ArcStartColor" Value="#FFB300" />
                <Setter Property="ArcEndColor" Value="#FFE082" />
                <Setter Property="MajorTickColor" Value="#C8E6C9" />
                <Setter Property="MinorTickColor" Value="#4F5A50" />
                <Setter Property="LabelColor" Value="#A5D6A7" />
                <Setter Property="ValueColor" Value="#FFE082" />
                <Setter Property="UnitColor" Value="#80CBC4" />
                <Setter Property="PivotColor" Value="#FFB300" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="Auto,*,Auto"
          BackgroundColor="#0A0E12">

        <!-- コンパスリボン -->
        <controls:CompassRibbon Grid.Row="0"
                                Margin="12,12,12,4"
                                Heading="{Binding Heading}" />

        <!-- 水平儀 -->
        <controls:AttitudeIndicator Grid.Row="1"
                                    Margin="12"
                                    Pitch="{Binding Pitch}"
                                    Roll="{Binding Roll}" />

        <!-- 計器 -->
        <Grid Grid.Row="2"
              Margin="4,0,4,8"
              HeightRequest="150"
              ColumnDefinitions="*,*,*">
            <controls:Gauge Grid.Column="0"
                            Style="{StaticResource CockpitGauge}"
                            MinValue="0"
                            MaxValue="500"
                            LabelInterval="100"
                            MajorTickInterval="100"
                            MinorTickInterval="25"
                            Unit="kt"
                            Value="{Binding Speed}" />
            <controls:Gauge Grid.Column="1"
                            Style="{StaticResource CockpitGauge}"
                            MinValue="0"
                            MaxValue="15"
                            LabelInterval="5"
                            MajorTickInterval="5"
                            MinorTickInterval="1"
                            Unit="kft"
                            ValueFormat="{}{0:F1}"
                            Value="{Binding AltitudeK}" />
            <controls:Gauge Grid.Column="2"
                            Style="{StaticResource CockpitGauge}"
                            MinValue="0"
                            MaxValue="100"
                            LabelInterval="20"
                            MajorTickInterval="20"
                            MinorTickInterval="5"
                            Unit="%"
                            Value="{Binding Rpm}" />
        </Grid>

    </Grid>

</ContentView>
