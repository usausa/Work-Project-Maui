<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:graphics="clr-namespace:Template.MobileApp.Graphics"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UIEnergyView"
             x:DataType="{x:Type module:UIEnergyViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UIEnergyViewModel}"
             shell:ShellProperty.Title="Energy"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="*">
        <graphics:SkiaSceneView Grid.Row="0" Scene="{Binding Scene}" />
    </Grid>

</ContentView>
