<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UIKitNotifyView"
             x:DataType="{x:Type module:UIKitNotifyViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UIKitNotifyViewModel}"
             shell:ShellProperty.Title="Kit Notifications"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootList" TargetType="CollectionView">
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

            <Style x:Key="ItemBorder" TargetType="Border">
                <Setter Property="Margin" Value="12,6" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten2}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            </Style>

            <Style x:Key="IconBorder" TargetType="Border">
                <Setter Property="WidthRequest" Value="42" />
                <Setter Property="HeightRequest" Value="42" />
                <Setter Property="BackgroundColor" Value="{StaticResource BlueLighten4}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 21" />
            </Style>

            <Style x:Key="IconLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="MaterialIcons" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="TextColor" Value="{StaticResource BlueDefault}" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>

            <Style x:Key="TitleLabel" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken4}" />
            </Style>

            <Style x:Key="DescLabel" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken1}" />
            </Style>

            <Style x:Key="TimeLabel" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource GrayDarken1}" />
                <Setter Property="VerticalOptions" Value="Start" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>

    <CollectionView Style="{StaticResource RootList}"
                    ItemsSource="{Binding Notifications}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="module:UIKitNotifyItem">
                <Border Style="{StaticResource ItemBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type module:UIKitNotifyViewModel}}, Path=ReadCommand, x:DataType={x:Type module:UIKitNotifyViewModel}}"
                                              CommandParameter="{Binding .}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsUnread}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource BlueLighten5}" />
                            <Setter Property="Stroke" Value="{StaticResource BlueLighten3}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                          ColumnSpacing="12">
                        <!-- 未読アクセントバー -->
                        <BoxView Grid.Column="0"
                                 WidthRequest="4"
                                 CornerRadius="2"
                                 Color="{StaticResource BlueDefault}"
                                 IsVisible="{Binding IsUnread}" />
                        <Border Grid.Column="1" Style="{StaticResource IconBorder}">
                            <Label Style="{StaticResource IconLabel}" Text="{Binding Icon}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabel}" Text="{Binding Title}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsUnread}"
                                                 Value="False">
                                        <Setter Property="FontAttributes" Value="None" />
                                        <Setter Property="TextColor" Value="{StaticResource GrayDarken2}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Style="{StaticResource DescLabel}" Text="{Binding Description}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3"
                                             Spacing="6">
                            <Label Style="{StaticResource TimeLabel}" Text="{Binding Time}" />
                            <!-- 未読ドット -->
                            <BoxView WidthRequest="8"
                                     HeightRequest="8"
                                     CornerRadius="4"
                                     HorizontalOptions="End"
                                     Color="{StaticResource BlueDefault}"
                                     IsVisible="{Binding IsUnread}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentView>
