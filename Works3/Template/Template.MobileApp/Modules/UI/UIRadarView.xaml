<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.UI"
             x:Class="Template.MobileApp.Modules.UI.UIRadarView"
             x:DataType="{x:Type module:UIRadarViewModel}"
             s:BindingContextResolver.Type="{x:Type module:UIRadarViewModel}"
             shell:ShellProperty.Title="Radar"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="StatusLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="Lime" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="*,Auto"
          BackgroundColor="#061206">

        <controls:RadarScreen Grid.Row="0"
                              Targets="{Binding Targets}" />

        <!-- 飾りステータス -->
        <HorizontalStackLayout Grid.Row="1"
                               HorizontalOptions="Center"
                               Spacing="24"
                               Padding="0,0,0,16">
            <Label Style="{StaticResource StatusLabel}"
                   Text="SWEEP 120°/s" />
            <Label Style="{StaticResource StatusLabel}"
                   Text="RANGE 5.0km" />
            <Label Style="{StaticResource StatusLabel}"
                   Text="MODE PULSE" />
            <Label Style="{StaticResource StatusLabel}"
                   Text="{Binding TargetCount, StringFormat='TGT {0}'}" />
        </HorizontalStackLayout>
    </Grid>

</ContentView>
