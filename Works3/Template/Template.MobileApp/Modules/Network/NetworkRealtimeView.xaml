<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Network"
             x:Class="Template.MobileApp.Modules.Network.NetworkRealtimeView"
             x:DataType="{x:Type module:NetworkRealtimeViewModel}"
             s:BindingContextResolver.Type="{x:Type module:NetworkRealtimeViewModel}"
             shell:ShellProperty.Title="Realtime"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="StatBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="8" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten1}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView BackgroundColor="{StaticResource GrayLighten5}">
        <VerticalStackLayout Padding="12"
                             Spacing="12">

            <Border Style="{StaticResource StatBorder}"
                    behaviors:AnimationOption.EnterAnimation="FadeUp">
                <controls:StatControl HeightRequest="110"
                                      DataSet="{Binding CpuLoadSet}"
                                      GraphColor="{StaticResource BlueDefault}"
                                      Label="CPU used" />
            </Border>

            <Border Style="{StaticResource StatBorder}"
                    behaviors:AnimationOption.EnterAnimation="FadeUp"
                    behaviors:AnimationOption.EnterDelay="80">
                <controls:StatControl HeightRequest="110"
                                      DataSet="{Binding MemoryLoadSet}"
                                      GraphColor="{StaticResource GreenDefault}"
                                      Label="Memory used" />
            </Border>

            <Border Style="{StaticResource StatBorder}"
                    behaviors:AnimationOption.EnterAnimation="FadeUp"
                    behaviors:AnimationOption.EnterDelay="160">
                <controls:StatControl HeightRequest="110"
                                      DataSet="{Binding NetworkLoadSet}"
                                      GraphColor="{StaticResource OrangeDefault}"
                                      Label="Network I/O" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
