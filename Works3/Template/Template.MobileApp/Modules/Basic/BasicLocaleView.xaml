<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Basic"
             xmlns:strings="clr-namespace:Template.MobileApp.Resources.Strings"
             x:Class="Template.MobileApp.Modules.Basic.BasicLocaleView"
             x:DataType="{x:Type module:BasicLocaleViewModel}"
             s:BindingContextResolver.Type="{x:Type module:BasicLocaleViewModel}"
             shell:ShellProperty.Title="Locale"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootScroll"
                   TargetType="ScrollView">
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten5}" />
            </Style>

            <Style x:Key="PageStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Spacing" Value="12" />
            </Style>

            <Style x:Key="CultureGrid"
                   TargetType="Grid">
                <Setter Property="Padding" Value="0,4" />
                <Setter Property="RowSpacing" Value="8" />
            </Style>

            <Style x:Key="CardContentStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Padding" Value="0,4" />
                <Setter Property="Spacing" Value="10" />
            </Style>

            <Style x:Key="ResourceGroupStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="2" />
            </Style>

            <Style x:Key="KeyLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

            <Style x:Key="ResourceValueLabel"
                   TargetType="Label"
                   BasedOn="{StaticResource ValueLabel}">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            </Style>

            <Style x:Key="CardDivider"
                   TargetType="BoxView">
                <Setter Property="HeightRequest" Value="1" />
                <Setter Property="Color" Value="{StaticResource GrayLighten2}" />
            </Style>

            <Style x:Key="NoteLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView Style="{StaticResource RootScroll}">
        <VerticalStackLayout Style="{StaticResource PageStack}">

            <controls:InfoCard Title="Current culture"
                               Icon="{x:Static fonts:MaterialIcons.Language}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp">
                <Grid Style="{StaticResource CultureGrid}"
                      RowDefinitions="Auto,Auto"
                      ColumnDefinitions="2*,3*">
                    <Label Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="Culture" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding CultureName}" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Style="{StaticResource NameLabel}"
                           Text="UICulture" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource ValueLabel}"
                           Text="{Binding UICultureName}" />
                </Grid>
            </controls:InfoCard>

            <controls:InfoCard Title="Localized resources"
                               Icon="{x:Static fonts:MaterialIcons.Translate}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="100">
                <VerticalStackLayout Style="{StaticResource CardContentStack}">
                    <VerticalStackLayout Style="{StaticResource ResourceGroupStack}">
                        <Label Style="{StaticResource KeyLabel}"
                               Text="Names.Label" />
                        <Label Style="{StaticResource ResourceValueLabel}"
                               Text="{x:Static strings:Names.Label}" />
                    </VerticalStackLayout>
                    <BoxView Style="{StaticResource CardDivider}" />
                    <VerticalStackLayout Style="{StaticResource ResourceGroupStack}">
                        <Label Style="{StaticResource KeyLabel}"
                               Text="Messages.Hello_World" />
                        <Label Style="{StaticResource ResourceValueLabel}"
                               Text="{x:Static strings:Messages.Hello_World}" />
                    </VerticalStackLayout>
                    <Label Style="{StaticResource NoteLabel}"
                           Text="Values switch with the system language (en / ja resx)" />
                </VerticalStackLayout>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
