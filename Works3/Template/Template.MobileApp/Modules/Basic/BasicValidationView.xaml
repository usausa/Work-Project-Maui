<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:markup="clr-namespace:Template.MobileApp.Markup"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Basic"
             x:Class="Template.MobileApp.Modules.Basic.BasicValidationView"
             x:DataType="{x:Type module:BasicValidationViewModel}"
             s:BindingContextResolver.Type="{x:Type module:BasicValidationViewModel}"
             shell:ShellProperty.Title="Validation"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <ContentView.Behaviors>
        <s:ValidationFocusBehavior Request="{Binding ValidationFocusRequest}" />
    </ContentView.Behaviors>

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="FieldCaptionLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

            <Style x:Key="FieldBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten1}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            </Style>

            <Style x:Key="ActionButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="behaviors:ButtonOption.PressEffect" Value="True" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView BackgroundColor="{StaticResource GrayLighten5}">
        <VerticalStackLayout Padding="12"
                             Spacing="12">

            <controls:InfoCard Title="Validate on Unfocused"
                               Icon="{x:Static fonts:MaterialIcons.Fact_check}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp">
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource FieldCaptionLabel}"
                           Text="Text1 (clears error on focus, validates on unfocused)" />
                    <Border Style="{StaticResource FieldBorder}"
                            behaviors:AnimationOption.HighlightTrigger="{Binding Errors[Text1]}"
                            behaviors:AnimationOption.HighlightColor="{StaticResource RedLighten4}">
                        <Entry s:Behavior.Key="Text1"
                               s:ValidationProperty.ClearErrorOnFocus="True" s:ValidationProperty.ValidateOnUnfocused="True"
                               behaviors:Focus.FocusedStroke="{StaticResource BlueDefault}"
                               behaviors:Focus.FocusedThickness="2.5"
                               Text="{Binding Text1}" />
                    </Border>
                    <Label Style="{StaticResource ErrorMessageLabel}"
                           IsVisible="{Binding Errors[Text1], Converter={StaticResource NotEmptyConverter}}"
                           Text="{Binding Errors[Text1]}"
                           behaviors:AnimationOption.FadeInTrigger="{Binding Errors[Text1]}" />
                </VerticalStackLayout>
            </controls:InfoCard>

            <controls:InfoCard Title="Manual Validation"
                               Icon="{x:Static fonts:MaterialIcons.Rule}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="100">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource FieldCaptionLabel}"
                           Text="Text2" />
                    <Border Style="{StaticResource FieldBorder}"
                            behaviors:AnimationOption.HighlightTrigger="{Binding Errors[Text2]}"
                            behaviors:AnimationOption.HighlightColor="{StaticResource RedLighten4}">
                        <Entry s:Behavior.Key="Text2"
                               behaviors:Focus.FocusedStroke="{StaticResource BlueDefault}"
                               behaviors:Focus.FocusedThickness="2.5"
                               Text="{Binding Text2}" />
                    </Border>
                    <Label Style="{StaticResource ErrorMessageLabel}"
                           IsVisible="{Binding Errors[Text2], Converter={StaticResource NotEmptyConverter}}"
                           Text="{Binding Errors[Text2]}"
                           behaviors:AnimationOption.FadeInTrigger="{Binding Errors[Text2]}" />
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Error}, Color={StaticResource RedDefault}, Size=18}"
                                Command="{Binding ErrorCommand}"
                                Text="Error" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Check_circle}, Color={StaticResource GreenDefault}, Size=18}"
                                Command="{Binding ClearCommand}"
                                Text="Clear" />
                    </Grid>
                </VerticalStackLayout>
            </controls:InfoCard>

            <controls:InfoCard Title="Focus Request"
                               Icon="{x:Static fonts:MaterialIcons.Input}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="200">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource FieldCaptionLabel}"
                           Text="Moves focus to the first field with an error" />
                    <Button Style="{StaticResource ActionButton}"
                            ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Input}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                            Command="{Binding FocusCommand}"
                            Text="Focus" />
                </VerticalStackLayout>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
