<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.View"
             xmlns:extended="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
             x:Class="Template.MobileApp.Modules.View.ViewLottieView"
             x:DataType="{x:Type module:ViewLottieViewModel}"
             s:BindingContextResolver.Type="{x:Type module:ViewLottieViewModel}"
             shell:ShellProperty.Title="Lottie"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function3Text="Reset"
             shell:ShellProperty.Function4Text="{Binding IsAnimationEnabled, Converter={s:BoolToText True='Pause', False='Play'}}"
             shell:ShellProperty.Function1Enabled="True"
             shell:ShellProperty.Function3Enabled="True"
             shell:ShellProperty.Function4Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="TimeLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

            <Style x:Key="TransportButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="0" />
                <Setter Property="WidthRequest" Value="48" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="CornerRadius" Value="24" />
                <Setter Property="FontFamily" Value="{x:Static fonts:MaterialIcons.FontFamily}" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten3}" />
                <Setter Property="behaviors:ButtonOption.PressEffect" Value="True" />
            </Style>

            <Style x:Key="MainTransportButton"
                   TargetType="Button"
                   BasedOn="{StaticResource TransportButton}">
                <Setter Property="WidthRequest" Value="64" />
                <Setter Property="HeightRequest" Value="64" />
                <Setter Property="CornerRadius" Value="32" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="*,Auto"
          BackgroundColor="{StaticResource GrayLighten5}">

        <Border Grid.Row="0"
                Margin="12"
                Padding="8"
                BackgroundColor="White"
                Stroke="{StaticResource GrayLighten1}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                behaviors:AnimationOption.EnterAnimation="FadeUp">
            <extended:SKLottieView Source="Lottie/popping.json"
                                   Progress="{Binding Progress}"
                                   Duration="{Binding Duration}"
                                   IsAnimationEnabled="{Binding IsAnimationEnabled}" />
        </Border>

        <!-- プレイヤーコントロール -->
        <Border Grid.Row="1"
                Padding="16,12"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16,16,0,0">
            <VerticalStackLayout Spacing="8">

                <VerticalStackLayout Spacing="2">
                    <Slider Minimum="0"
                            Maximum="{Binding DurationSeconds}"
                            Value="{Binding ProgressSeconds, Mode=OneWay}"
                            behaviors:SliderOption.DragCompletedCommand="{Binding SeekCommand}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Style="{StaticResource TimeLabel}"
                               Text="{Binding Progress, StringFormat='{0:mm\\:ss\\.f}'}" />
                        <Label Grid.Column="1"
                               Style="{StaticResource TimeLabel}"
                               Text="{Binding Duration, StringFormat='{0:mm\\:ss\\.f}'}" />
                    </Grid>
                </VerticalStackLayout>

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="24">
                    <Button Style="{StaticResource TransportButton}"
                            VerticalOptions="Center"
                            Command="{Binding ResetCommand}"
                            Text="{x:Static fonts:MaterialIcons.Replay}" />
                    <Button Style="{StaticResource MainTransportButton}"
                            behaviors:ButtonOption.HapticFeedback="True"
                            Command="{Binding PlayPauseCommand}"
                            Text="{x:Static fonts:MaterialIcons.Play_arrow}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsAnimationEnabled}"
                                         Value="True">
                                <Setter Property="Text" Value="{x:Static fonts:MaterialIcons.Pause}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentView>
