<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:drawing="clr-namespace:Template.MobileApp.Graphics.Drawing"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:markup="clr-namespace:Template.MobileApp.Markup"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.View"
             x:Class="Template.MobileApp.Modules.View.ViewGraphicsView"
             x:DataType="{x:Type module:ViewGraphicsViewModel}"
             s:BindingContextResolver.Type="{x:Type module:ViewGraphicsViewModel}"
             shell:ShellProperty.Title="Graphics"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootScroll"
                   TargetType="ScrollView">
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten5}" />
            </Style>

            <Style x:Key="PageStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Spacing" Value="12" />
            </Style>

            <Style x:Key="CardContentStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="10" />
            </Style>

            <Style x:Key="CanvasBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="0" />
                <Setter Property="HeightRequest" Value="280" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten2}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            </Style>

            <Style x:Key="CountChip"
                   TargetType="controls:StatusChip">
                <Setter Property="HorizontalOptions" Value="Start" />
            </Style>

            <Style x:Key="ActionRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="8" />
                <Setter Property="RowSpacing" Value="8" />
            </Style>

            <Style x:Key="ActionButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="behaviors:ButtonOption.PressEffect" Value="True" />
            </Style>

            <Style x:Key="NoteLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView Style="{StaticResource RootScroll}">
        <VerticalStackLayout Style="{StaticResource PageStack}">

            <controls:InfoCard Title="Shape drawing"
                               Icon="{x:Static fonts:MaterialIcons.Format_paint}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp">
                <VerticalStackLayout Style="{StaticResource CardContentStack}">

                    <Border Style="{StaticResource CanvasBorder}">
                        <drawing:DrawingControl Drawing="{Binding Drawing}" />
                    </Border>

                    <controls:StatusChip Style="{StaticResource CountChip}"
                                         Icon="{x:Static fonts:MaterialIcons.Palette}"
                                         Text="{Binding ShapeCount, StringFormat='{0} shapes'}" />

                    <Grid Style="{StaticResource ActionRowGrid}"
                          ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto">
                        <Button Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding AddLineCommand}"
                                Text="Add line" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding AddCircleCommand}"
                                Text="Add circle" />
                        <Button Grid.Row="1" Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding AddRectCommand}"
                                Text="Add rect" />
                        <Button Grid.Row="1" Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                ImageSource="{markup:Material Glyph={x:Static fonts:MaterialIcons.Do_not_disturb}, Color={StaticResource BlueGrayDarken1}, Size=18}"
                                Command="{Binding ClearCommand}"
                                Text="Clear" />
                    </Grid>

                    <Label Style="{StaticResource NoteLabel}"
                           Text="Shapes are added to a DrawingControl and redrawn with Invalidate()" />

                </VerticalStackLayout>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
