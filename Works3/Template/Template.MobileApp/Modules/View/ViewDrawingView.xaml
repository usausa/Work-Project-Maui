<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.View"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Template.MobileApp.Modules.View.ViewDrawingView"
             x:DataType="{x:Type module:ViewDrawingViewModel}"
             s:BindingContextResolver.Type="{x:Type module:ViewDrawingViewModel}"
             shell:ShellProperty.Title="Drawing"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function3Text="Clear"
             shell:ShellProperty.Function4Text="Save"
             shell:ShellProperty.Function1Enabled="True"
             shell:ShellProperty.Function3Enabled="True"
             shell:ShellProperty.Function4Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootGrid"
                   TargetType="Grid"
                   BasedOn="{StaticResource FillGrid}">
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten5}" />
            </Style>

            <Style x:Key="CanvasView"
                   TargetType="toolkit:DrawingView">
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

            <Style x:Key="PaletteBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten2}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 0" />
            </Style>

            <Style x:Key="PaletteStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="8" />
            </Style>

            <Style x:Key="ChipRow"
                   TargetType="HorizontalStackLayout">
                <Setter Property="Spacing" Value="10" />
            </Style>

            <Style x:Key="ColorChipBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="0" />
                <Setter Property="WidthRequest" Value="36" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="StrokeShape" Value="RoundRectangle 18" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="3" />
            </Style>

            <Style x:Key="BlackChip"
                   TargetType="Border"
                   BasedOn="{StaticResource ColorChipBorder}">
                <Setter Property="BackgroundColor" Value="Black" />
                <Style.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding LineColor}"
                                 Value="{x:Static Colors.Black}">
                        <Setter Property="Stroke" Value="{StaticResource BlueGrayDarken3}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="RedChip"
                   TargetType="Border"
                   BasedOn="{StaticResource ColorChipBorder}">
                <Setter Property="BackgroundColor" Value="{StaticResource RedDefault}" />
                <Style.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding LineColor}"
                                 Value="{StaticResource RedDefault}">
                        <Setter Property="Stroke" Value="{StaticResource BlueGrayDarken3}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="BlueChip"
                   TargetType="Border"
                   BasedOn="{StaticResource ColorChipBorder}">
                <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                <Style.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding LineColor}"
                                 Value="{StaticResource BlueDefault}">
                        <Setter Property="Stroke" Value="{StaticResource BlueGrayDarken3}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GreenChip"
                   TargetType="Border"
                   BasedOn="{StaticResource ColorChipBorder}">
                <Setter Property="BackgroundColor" Value="{StaticResource GreenDefault}" />
                <Style.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding LineColor}"
                                 Value="{StaticResource GreenDefault}">
                        <Setter Property="Stroke" Value="{StaticResource BlueGrayDarken3}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OrangeChip"
                   TargetType="Border"
                   BasedOn="{StaticResource ColorChipBorder}">
                <Setter Property="BackgroundColor" Value="{StaticResource OrangeDefault}" />
                <Style.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding LineColor}"
                                 Value="{StaticResource OrangeDefault}">
                        <Setter Property="Stroke" Value="{StaticResource BlueGrayDarken3}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PurpleChip"
                   TargetType="Border"
                   BasedOn="{StaticResource ColorChipBorder}">
                <Setter Property="BackgroundColor" Value="{StaticResource PurpleDefault}" />
                <Style.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding LineColor}"
                                 Value="{StaticResource PurpleDefault}">
                        <Setter Property="Stroke" Value="{StaticResource BlueGrayDarken3}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WidthRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="8" />
            </Style>

            <Style x:Key="WidthIcon"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="{x:Static fonts:MaterialIcons.FontFamily}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken1}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="WidthValueLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
                <Setter Property="HorizontalTextAlignment" Value="End" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="PreviewGrid"
                   TargetType="Grid">
                <Setter Property="Padding" Value="12" />
            </Style>

            <Style x:Key="PreviewBorder"
                   TargetType="Border">
                <Setter Property="Margin" Value="0,6,0,0" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten1}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            </Style>

            <Style x:Key="EmptyStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="Spacing" Value="6" />
            </Style>

            <Style x:Key="EmptyIconLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="{x:Static fonts:MaterialIcons.FontFamily}" />
                <Setter Property="FontSize" Value="36" />
                <Setter Property="TextColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="EmptyHintLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource RootGrid}"
          RowDefinitions="2*,Auto,*">

        <toolkit:DrawingView Grid.Row="0"
                             Style="{StaticResource CanvasView}"
                             behaviors:DrawingBind.Controller="{Binding Controller}"
                             LineColor="{Binding LineColor}"
                             LineWidth="{Binding LineWidth}"
                             IsMultiLineModeEnabled="True" />

        <!-- パレット -->
        <Border Grid.Row="1"
                Style="{StaticResource PaletteBorder}">
            <VerticalStackLayout Style="{StaticResource PaletteStack}">

                <HorizontalStackLayout Style="{StaticResource ChipRow}">
                    <Border Style="{StaticResource BlackChip}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                  CommandParameter="{x:Static Colors.Black}" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource RedChip}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                  CommandParameter="{StaticResource RedDefault}" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource BlueChip}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                  CommandParameter="{StaticResource BlueDefault}" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource GreenChip}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                  CommandParameter="{StaticResource GreenDefault}" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource OrangeChip}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                  CommandParameter="{StaticResource OrangeDefault}" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource PurpleChip}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                  CommandParameter="{StaticResource PurpleDefault}" />
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>

                <Grid Style="{StaticResource WidthRowGrid}"
                      ColumnDefinitions="Auto,*,40">
                    <Label Grid.Column="0"
                           Style="{StaticResource WidthIcon}"
                           Text="{x:Static fonts:MaterialIcons.Edit}" />
                    <Slider Grid.Column="1"
                            Minimum="1"
                            Maximum="24"
                            Value="{Binding LineWidth}" />
                    <Label Grid.Column="2"
                           Style="{StaticResource WidthValueLabel}"
                           Text="{Binding LineWidth, StringFormat='{0:F0}'}" />
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- 保存プレビュー -->
        <Grid Grid.Row="2"
              Style="{StaticResource PreviewGrid}"
              RowDefinitions="Auto,*">
            <Label Grid.Row="0"
                   Style="{StaticResource NameLabel}"
                   Text="Preview" />
            <Border Grid.Row="1"
                    Style="{StaticResource PreviewBorder}">
                <Grid>
                    <Image Source="{Binding Image}"
                           Aspect="AspectFit"
                           IsVisible="{Binding HasImage}" />
                    <VerticalStackLayout Style="{StaticResource EmptyStack}"
                                         IsVisible="{Binding HasImage, Converter={StaticResource ReverseConverter}}">
                        <Label Style="{StaticResource EmptyIconLabel}"
                               Text="{x:Static fonts:MaterialIcons.Format_paint}" />
                        <Label Style="{StaticResource EmptyHintLabel}"
                               Text="Draw and press Save to preview" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

    </Grid>

</ContentView>
