<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.View"
             x:Class="Template.MobileApp.Modules.View.ViewSvgView"
             x:DataType="{x:Type module:ViewSvgViewModel}"
             s:BindingContextResolver.Type="{x:Type module:ViewSvgViewModel}"
             shell:ShellProperty.Title="Svg"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootGrid"
                   TargetType="Grid"
                   BasedOn="{StaticResource FillGrid}">
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten5}" />
            </Style>

            <Style x:Key="FrameBorder"
                   TargetType="Border">
                <Setter Property="Margin" Value="12" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="{StaticResource GrayLighten1}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16" />
            </Style>

            <Style x:Key="FrameGrid"
                   TargetType="Grid">
                <Setter Property="RowSpacing" Value="8" />
            </Style>

            <Style x:Key="FileRow"
                   TargetType="HorizontalStackLayout">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="Spacing" Value="6" />
            </Style>

            <Style x:Key="FileIcon"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="{x:Static fonts:MaterialIcons.FontFamily}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken1}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="FileNameLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="SelectPanelBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16,16,0,0" />
            </Style>

            <Style x:Key="SelectRow"
                   TargetType="HorizontalStackLayout">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="Spacing" Value="12" />
            </Style>

            <Style x:Key="SelectChipButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="behaviors:ButtonOption.PressEffect" Value="True" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource RootGrid}"
          RowDefinitions="*,Auto">

        <Border Grid.Row="0"
                Style="{StaticResource FrameBorder}"
                behaviors:AnimationOption.EnterAnimation="FadeUp">
            <Grid Style="{StaticResource FrameGrid}"
                  RowDefinitions="*,Auto">
                <controls:SvgView Grid.Row="0"
                                  Svg="{Binding Svg}" />
                <HorizontalStackLayout Grid.Row="1"
                                       Style="{StaticResource FileRow}">
                    <Label Style="{StaticResource FileIcon}"
                           Text="{x:Static fonts:MaterialIcons.Palette}" />
                    <Label Style="{StaticResource FileNameLabel}"
                           Text="{Binding Selected, StringFormat='{0}.svg'}" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- SVG 切替 -->
        <Border Grid.Row="1"
                Style="{StaticResource SelectPanelBorder}">
            <HorizontalStackLayout Style="{StaticResource SelectRow}">
                <Button Style="{StaticResource SelectChipButton}"
                        Command="{Binding SelectCommand}"
                        CommandParameter="dotnet_bot"
                        Text=".NET Bot">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding Selected}"
                                     Value="dotnet_bot">
                            <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                            <Setter Property="TextColor" Value="White" />
                            <Setter Property="BorderColor" Value="{StaticResource BlueDefault}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Style="{StaticResource SelectChipButton}"
                        Command="{Binding SelectCommand}"
                        CommandParameter="vite"
                        Text="Vite">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding Selected}"
                                     Value="vite">
                            <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                            <Setter Property="TextColor" Value="White" />
                            <Setter Property="BorderColor" Value="{StaticResource BlueDefault}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Style="{StaticResource SelectChipButton}"
                        Command="{Binding SelectCommand}"
                        CommandParameter="react"
                        Text="React">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding Selected}"
                                     Value="react">
                            <Setter Property="BackgroundColor" Value="{StaticResource BlueDefault}" />
                            <Setter Property="TextColor" Value="White" />
                            <Setter Property="BorderColor" Value="{StaticResource BlueDefault}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>
        </Border>

    </Grid>

</ContentView>
