<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:data="clr-namespace:Template.MobileApp.Modules.Data"
             x:Class="Template.MobileApp.Modules.Data.DataView"
             x:DataType="{x:Type data:DataViewModel}"
             s:BindingContextResolver.Type="{x:Type data:DataViewModel}"
             shell:ShellProperty.Title="Data"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="ActionButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="behaviors:ButtonOption.PressEffect" Value="True" />
            </Style>

            <Style x:Key="ActionRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnDefinitions" Value="*,*" />
                <Setter Property="ColumnSpacing" Value="8" />
                <Setter Property="RowSpacing" Value="8" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView BackgroundColor="{StaticResource GrayLighten5}">
        <VerticalStackLayout Padding="12"
                             Spacing="12">

            <controls:InfoCard Title="CRUD"
                               Icon="{x:Static fonts:MaterialIcons.Storage}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp">
                <Grid Style="{StaticResource ActionRowGrid}"
                      RowDefinitions="Auto,Auto">
                    <Button Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding InsertCommand}"
                            Text="Insert" />
                    <Button Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding UpdateCommand}"
                            Text="Update" />
                    <Button Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding DeleteCommand}"
                            Text="Delete" />
                    <Button Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding QueryCommand}"
                            Text="Query" />
                </Grid>
            </controls:InfoCard>

            <controls:InfoCard Title="Bulk"
                               Icon="{x:Static fonts:MaterialIcons.Dns}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="100">
                <VerticalStackLayout Spacing="10">

                    <HorizontalStackLayout Spacing="8"
                                           Padding="0,4">
                        <Label FontFamily="JetBrainsMono"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BlueGrayDarken3}"
                               behaviors:LabelOption.CountUpValue="{Binding BulkDataCount}"
                               behaviors:LabelOption.CountUpDuration="500" />
                        <Label Style="{StaticResource NameLabel}"
                               VerticalOptions="End"
                               Margin="0,0,0,6"
                               Text="rows" />
                    </HorizontalStackLayout>

                    <Grid Style="{StaticResource ActionRowGrid}"
                          RowDefinitions="Auto,Auto">
                        <Button Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding BulkInsertCommand}"
                                Text="BulkInsert" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding DeleteAllCommand}"
                                Text="DeleteAll" />
                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding QueryAllCommand}"
                                Text="QueryAll" />
                    </Grid>

                </VerticalStackLayout>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
