<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:data="clr-namespace:Template.MobileApp.Modules.Data"
             x:Class="Template.MobileApp.Modules.Data.DataView"
             x:DataType="{x:Type data:DataViewModel}"
             s:BindingContextResolver.Type="{x:Type data:DataViewModel}"
             shell:ShellProperty.Title="Data"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="RootScroll"
                   TargetType="ScrollView">
                <Setter Property="BackgroundColor" Value="{StaticResource GrayLighten5}" />
            </Style>

            <Style x:Key="PageStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Spacing" Value="12" />
            </Style>

            <Style x:Key="ActionRowGrid"
                   TargetType="Grid">
                <Setter Property="ColumnDefinitions" Value="*,*" />
                <Setter Property="ColumnSpacing" Value="8" />
                <Setter Property="RowSpacing" Value="8" />
            </Style>

            <Style x:Key="ActionButton"
                   TargetType="Button">
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="behaviors:ButtonOption.PressEffect" Value="True" />
            </Style>

            <Style x:Key="BulkStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="10" />
            </Style>

            <Style x:Key="CountRow"
                   TargetType="HorizontalStackLayout">
                <Setter Property="Padding" Value="0,4" />
                <Setter Property="Spacing" Value="8" />
            </Style>

            <Style x:Key="CountValueLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken3}" />
            </Style>

            <Style x:Key="CountUnitLabel"
                   TargetType="Label"
                   BasedOn="{StaticResource NameLabel}">
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="VerticalOptions" Value="End" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <ScrollView Style="{StaticResource RootScroll}">
        <VerticalStackLayout Style="{StaticResource PageStack}">

            <controls:InfoCard Title="CRUD"
                               Icon="{x:Static fonts:MaterialIcons.Storage}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp">
                <Grid Style="{StaticResource ActionRowGrid}"
                      RowDefinitions="Auto,Auto">
                    <Button Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding InsertCommand}"
                            Text="Insert" />
                    <Button Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding UpdateCommand}"
                            Text="Update" />
                    <Button Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding DeleteCommand}"
                            Text="Delete" />
                    <Button Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding QueryCommand}"
                            Text="Query" />
                </Grid>
            </controls:InfoCard>

            <controls:InfoCard Title="Bulk"
                               Icon="{x:Static fonts:MaterialIcons.Dns}"
                               behaviors:AnimationOption.EnterAnimation="FadeUp"
                               behaviors:AnimationOption.EnterDelay="100">
                <VerticalStackLayout Style="{StaticResource BulkStack}">

                    <HorizontalStackLayout Style="{StaticResource CountRow}">
                        <Label Style="{StaticResource CountValueLabel}"
                               behaviors:LabelOption.CountUpValue="{Binding BulkDataCount}"
                               behaviors:LabelOption.CountUpDuration="500" />
                        <Label Style="{StaticResource CountUnitLabel}"
                               Text="rows" />
                    </HorizontalStackLayout>

                    <Grid Style="{StaticResource ActionRowGrid}"
                          RowDefinitions="Auto,Auto">
                        <Button Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding BulkInsertCommand}"
                                Text="BulkInsert" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding DeleteAllCommand}"
                                Text="DeleteAll" />
                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding QueryAllCommand}"
                                Text="QueryAll" />
                    </Grid>

                </VerticalStackLayout>
            </controls:InfoCard>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
