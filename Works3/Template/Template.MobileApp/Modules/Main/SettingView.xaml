<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Main"
             x:Class="Template.MobileApp.Modules.Main.SettingView"
             x:DataType="{x:Type module:SettingViewModel}"
             s:BindingContextResolver.Type="{x:Type module:SettingViewModel}"
             shell:ShellProperty.Title="Setting"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <s:NullToBoolConverter x:Key="EmptyConverter"
                                   HandleEmptyString="True"
                                   NullValue="True"
                                   NonNullValue="False" />

            <Style x:Key="RootGrid"
                   TargetType="Grid"
                   BasedOn="{StaticResource FillGrid}">
                <Setter Property="BackgroundColor" Value="Black" />
            </Style>

            <Style x:Key="GuideBorder"
                   TargetType="Border">
                <Setter Property="Margin" Value="0,12,0,0" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Start" />
                <Setter Property="BackgroundColor" Value="#99000000" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16" />
            </Style>

            <Style x:Key="GuideStack"
                   TargetType="HorizontalStackLayout">
                <Setter Property="Spacing" Value="6" />
            </Style>

            <Style x:Key="GuideIcon"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="{x:Static fonts:MaterialIcons.FontFamily}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="GuideLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="SettingPanelBorder"
                   TargetType="Border">
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16,16,0,0" />
            </Style>

            <Style x:Key="SettingPanelStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="10" />
            </Style>

            <Style x:Key="SectionHeaderGrid"
                   TargetType="Grid">
                <Setter Property="ColumnSpacing" Value="8" />
            </Style>

            <Style x:Key="SectionHeaderIcon"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="{x:Static fonts:MaterialIcons.FontFamily}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="TextColor" Value="{StaticResource BlueGrayDarken2}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="SectionHeaderLabel"
                   TargetType="Label"
                   BasedOn="{StaticResource NameLabel}">
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="SettingGroupStack"
                   TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="2" />
            </Style>

            <Style x:Key="SettingCaptionLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

            <Style x:Key="SettingValueLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="LineBreakMode" Value="CharacterWrap" />
                <Setter Property="behaviors:AnimationOption.HighlightColor" Value="{StaticResource AmberLighten4}" />
            </Style>

            <Style x:Key="SettingEmptyLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="Text" Value="(not set)" />
            </Style>

            <Style x:Key="PanelDivider"
                   TargetType="BoxView">
                <Setter Property="HeightRequest" Value="1" />
                <Setter Property="Color" Value="{StaticResource GrayLighten2}" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource RootGrid}"
          RowDefinitions="*,Auto">

        <scanner:CameraView Grid.Row="0"
                            behaviors:BarcodeBind.Controller="{Binding Controller}"
                            OnDetectionFinishedCommand="{Binding DetectCommand}" />

        <!-- スキャンガイド -->
        <Border Grid.Row="0"
                Style="{StaticResource GuideBorder}">
            <HorizontalStackLayout Style="{StaticResource GuideStack}">
                <Label Style="{StaticResource GuideIcon}"
                       Text="{x:Static fonts:MaterialIcons.Qr_code}" />
                <Label Style="{StaticResource GuideLabel}"
                       Text="Scan configuration QR" />
            </HorizontalStackLayout>
        </Border>

        <!-- 設定値パネル -->
        <Border Grid.Row="1"
                Style="{StaticResource SettingPanelBorder}">
            <VerticalStackLayout Style="{StaticResource SettingPanelStack}">

                <Grid Style="{StaticResource SectionHeaderGrid}"
                      ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0"
                           Style="{StaticResource SectionHeaderIcon}"
                           Text="{x:Static fonts:MaterialIcons.Public}" />
                    <Label Grid.Column="1"
                           Style="{StaticResource SectionHeaderLabel}"
                           Text="Network" />
                </Grid>

                <VerticalStackLayout Style="{StaticResource SettingGroupStack}">
                    <Label Style="{StaticResource SettingCaptionLabel}"
                           Text="EndPoint" />
                    <Label Style="{StaticResource SettingValueLabel}"
                           IsVisible="{Binding ApiEndPoint, Converter={StaticResource NotEmptyConverter}}"
                           Text="{Binding ApiEndPoint}"
                           behaviors:AnimationOption.HighlightTrigger="{Binding ApiEndPoint}" />
                    <Label Style="{StaticResource SettingEmptyLabel}"
                           IsVisible="{Binding ApiEndPoint, Converter={StaticResource EmptyConverter}}" />
                </VerticalStackLayout>

                <BoxView Style="{StaticResource PanelDivider}" />

                <Grid Style="{StaticResource SectionHeaderGrid}"
                      ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0"
                           Style="{StaticResource SectionHeaderIcon}"
                           Text="{x:Static fonts:MaterialIcons.Memory}" />
                    <Label Grid.Column="1"
                           Style="{StaticResource SectionHeaderLabel}"
                           Text="AI Service" />
                </Grid>

                <VerticalStackLayout Style="{StaticResource SettingGroupStack}">
                    <Label Style="{StaticResource SettingCaptionLabel}"
                           Text="EndPoint" />
                    <Label Style="{StaticResource SettingValueLabel}"
                           IsVisible="{Binding AIServiceEndPoint, Converter={StaticResource NotEmptyConverter}}"
                           Text="{Binding AIServiceEndPoint}"
                           behaviors:AnimationOption.HighlightTrigger="{Binding AIServiceEndPoint}" />
                    <Label Style="{StaticResource SettingEmptyLabel}"
                           IsVisible="{Binding AIServiceEndPoint, Converter={StaticResource EmptyConverter}}" />
                </VerticalStackLayout>

                <VerticalStackLayout Style="{StaticResource SettingGroupStack}">
                    <Label Style="{StaticResource SettingCaptionLabel}"
                           Text="ServiceKey" />
                    <Label Style="{StaticResource SettingValueLabel}"
                           Text="{Binding AIServiceKey, Converter={StaticResource MaskTextConverter}}"
                           behaviors:AnimationOption.HighlightTrigger="{Binding AIServiceKey}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentView>
