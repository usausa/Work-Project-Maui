<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:s="http://smart/maui"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             xmlns:shell="clr-namespace:Template.MobileApp.Shell"
             xmlns:behaviors="clr-namespace:Template.MobileApp.Behaviors"
             xmlns:controls="clr-namespace:Template.MobileApp.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:module="clr-namespace:Template.MobileApp.Modules.Main"
             x:Class="Template.MobileApp.Modules.Main.SettingView"
             x:DataType="{x:Type module:SettingViewModel}"
             s:BindingContextResolver.Type="{x:Type module:SettingViewModel}"
             shell:ShellProperty.Title="Setting"
             shell:ShellProperty.Function1Text="Back"
             shell:ShellProperty.Function1Enabled="True">

    <!-- ReSharper disable Xaml.RedundantResource -->
    <ContentView.Resources>
        <ResourceDictionary>

            <Style x:Key="SettingCaptionLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>

            <s:NullToBoolConverter x:Key="EmptyConverter"
                                   HandleEmptyString="True"
                                   NullValue="True"
                                   NonNullValue="False" />

            <Style x:Key="SettingValueLabel"
                   TargetType="Label">
                <Setter Property="FontFamily" Value="JetBrainsMono" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="LineBreakMode" Value="CharacterWrap" />
                <Setter Property="behaviors:AnimationOption.HighlightColor" Value="{StaticResource AmberLighten4}" />
            </Style>

            <Style x:Key="SettingEmptyLabel"
                   TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource GrayLighten1}" />
                <Setter Property="Text" Value="(not set)" />
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>
    <!-- ReSharper restore Xaml.RedundantResource -->

    <Grid Style="{StaticResource FillGrid}"
          RowDefinitions="*,Auto"
          BackgroundColor="Black">

        <scanner:CameraView Grid.Row="0"
                            behaviors:BarcodeBind.Controller="{Binding Controller}"
                            OnDetectionFinishedCommand="{Binding DetectCommand}" />

        <!-- スキャンガイド -->
        <Border Grid.Row="0"
                Margin="0,12,0,0"
                Padding="12,6"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                BackgroundColor="#99000000"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16">
            <HorizontalStackLayout Spacing="6">
                <Label FontFamily="{x:Static fonts:MaterialIcons.FontFamily}"
                       FontSize="16"
                       TextColor="White"
                       VerticalOptions="Center"
                       Text="{x:Static fonts:MaterialIcons.Qr_code}" />
                <Label FontSize="14"
                       TextColor="White"
                       VerticalOptions="Center"
                       Text="Scan configuration QR" />
            </HorizontalStackLayout>
        </Border>

        <!-- 設定値パネル -->
        <Border Grid.Row="1"
                Padding="16,12"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16,16,0,0">
            <VerticalStackLayout Spacing="10">

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="8">
                    <Label Grid.Column="0"
                           FontFamily="{x:Static fonts:MaterialIcons.FontFamily}"
                           FontSize="20"
                           TextColor="{StaticResource BlueGrayDarken2}"
                           VerticalOptions="Center"
                           Text="{x:Static fonts:MaterialIcons.Public}" />
                    <Label Grid.Column="1"
                           Style="{StaticResource NameLabel}"
                           VerticalOptions="Center"
                           Text="Network" />
                </Grid>

                <VerticalStackLayout Spacing="2">
                    <Label Style="{StaticResource SettingCaptionLabel}"
                           Text="EndPoint" />
                    <Label Style="{StaticResource SettingValueLabel}"
                           IsVisible="{Binding ApiEndPoint, Converter={StaticResource NotEmptyConverter}}"
                           Text="{Binding ApiEndPoint}"
                           behaviors:AnimationOption.HighlightTrigger="{Binding ApiEndPoint}" />
                    <Label Style="{StaticResource SettingEmptyLabel}"
                           IsVisible="{Binding ApiEndPoint, Converter={StaticResource EmptyConverter}}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         Color="{StaticResource GrayLighten2}" />

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="8">
                    <Label Grid.Column="0"
                           FontFamily="{x:Static fonts:MaterialIcons.FontFamily}"
                           FontSize="20"
                           TextColor="{StaticResource BlueGrayDarken2}"
                           VerticalOptions="Center"
                           Text="{x:Static fonts:MaterialIcons.Memory}" />
                    <Label Grid.Column="1"
                           Style="{StaticResource NameLabel}"
                           VerticalOptions="Center"
                           Text="AI Service" />
                </Grid>

                <VerticalStackLayout Spacing="2">
                    <Label Style="{StaticResource SettingCaptionLabel}"
                           Text="EndPoint" />
                    <Label Style="{StaticResource SettingValueLabel}"
                           IsVisible="{Binding AIServiceEndPoint, Converter={StaticResource NotEmptyConverter}}"
                           Text="{Binding AIServiceEndPoint}"
                           behaviors:AnimationOption.HighlightTrigger="{Binding AIServiceEndPoint}" />
                    <Label Style="{StaticResource SettingEmptyLabel}"
                           IsVisible="{Binding AIServiceEndPoint, Converter={StaticResource EmptyConverter}}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="2">
                    <Label Style="{StaticResource SettingCaptionLabel}"
                           Text="ServiceKey" />
                    <Label Style="{StaticResource SettingValueLabel}"
                           Text="{Binding AIServiceKey, Converter={StaticResource MaskTextConverter}}"
                           behaviors:AnimationOption.HighlightTrigger="{Binding AIServiceKey}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentView>
